  // ============================================================
  // SEARCH TAB
  // ============================================================
  async function loadSearchResults(append = false) {
    const query = document.getElementById('search-input').value.trim();
    if (!query) return;
    if (isLoading) return;
    isLoading = true;
    if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`;

    try {
      if (currentSearchType === 'posts') {
        const data = await searchBskyPosts(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const posts = (data.posts || []).map(p => normalizeBskyPost({ post: p }));
        const html = posts.map(p => renderPostCard(p)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No results for "${escapeHtml(query)}"</div>`;
      } else if (currentSearchType === 'users') {
        const data = await searchBskyActors(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const html = (data.actors || []).map(a => renderBskyUserCard(a)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No users found for "${escapeHtml(query)}"</div>`;
      } else if (currentSearchType === 'feeds') {
        const data = await searchBskyFeeds(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const html = (data.feeds || []).map(f => renderFeedCard(f)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No feeds found for "${escapeHtml(query)}"</div>`;
      }
      attachAllListeners();
      initHlsVideos();
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">Search failed</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // INTERACTIONS
  // ============================================================
  function attachAllListeners() {
    // Bluesky likes
    document.querySelectorAll('.bsky-like-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!bskySession?.accessJwt) return;
        const uri = btn.dataset.uri;
        const cid = btn.dataset.cid;
        const countEl = btn.querySelector('.like-count');
        const count = parseInt(countEl.textContent) || 0;
        if (myLikes[uri]) {
          // Unlike
          btn.classList.remove('text-red-400');
          btn.innerHTML = `${ICON.heart} <span class="like-count">${Math.max(0, count - 1)}</span>`;
          try { await unlikeBskyPost(uri); } catch { btn.classList.add('text-red-400'); btn.innerHTML = `${ICON.heartFill} <span class="like-count">${count}</span>`; }
        } else {
          // Like
          btn.classList.add('text-red-400');
          btn.innerHTML = `${ICON.heartFill} <span class="like-count">${count + 1}</span>`;
          try { await likeBskyPost(uri, cid); } catch { btn.classList.remove('text-red-400'); btn.innerHTML = `${ICON.heart} <span class="like-count">${count}</span>`; }
        }
      });
    });

    // Bluesky reposts
    document.querySelectorAll('.bsky-repost-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!bskySession?.accessJwt) return;
        const uri = btn.dataset.uri;
        const cid = btn.dataset.cid;
        const countEl = btn.querySelector('.repost-count');
        const count = parseInt(countEl.textContent) || 0;
        if (myReposts[uri]) {
          btn.classList.remove('text-green-400');
          btn.innerHTML = `${ICON.repost} <span class="repost-count">${Math.max(0, count - 1)}</span>`;
          try { await unrepostBskyPost(uri); } catch { btn.classList.add('text-green-400'); btn.innerHTML = `${ICON.repost} <span class="repost-count">${count}</span>`; }
        } else {
          btn.classList.add('text-green-400');
          btn.innerHTML = `${ICON.repost} <span class="repost-count">${count + 1}</span>`;
          try { await repostBskyPost(uri, cid); } catch { btn.classList.remove('text-green-400'); btn.innerHTML = `${ICON.repost} <span class="repost-count">${count}</span>`; }
        }
      });
    });

    // Reply button → open thread
    document.querySelectorAll('.bsky-reply-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => openThread(btn.dataset.uri));
    });

    // Avatar click → open profile
    document.querySelectorAll('.bsky-avatar:not([data-bound])').forEach(el => {
      el.dataset.bound = '1';
      el.addEventListener('click', (e) => { e.preventDefault(); openProfile(el.dataset.handle); });
    });

    // Pirate Social likes
    document.querySelectorAll('.like-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!token) return alert('Sign in to like posts');
        const postId = btn.dataset.postId;
        const isLiked = btn.classList.contains('text-red-400');
        const method = isLiked ? 'DELETE' : 'POST';
        const res = await fetch(`${hubUrl}/api/interactions/like`, {
          method, headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId }),
        });
        const data = await res.json();
        btn.innerHTML = `${data.liked ? ICON.heartFill : ICON.heart} ${data.count}`;
        btn.classList.toggle('text-red-400', data.liked);
      });
    });

    // Pirate Social follows
    document.querySelectorAll('.follow-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!token) return;
        const userId = btn.dataset.userId;
        const res = await fetch(`${hubUrl}/api/interactions/follow`, {
          method: 'POST', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId }),
        });
        const data = await res.json();
        btn.textContent = data.following ? 'Following' : 'Follow';
      });
    });

    // Share buttons
    document.querySelectorAll('.share-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => openShareModal(btn.dataset.url, btn.dataset.title));
    });

    // Feed cards — click to load that feed's posts
    document.querySelectorAll('.feed-card:not([data-bound])').forEach(card => {
      card.dataset.bound = '1';
      card.addEventListener('click', () => {
        const uri = card.dataset.feedUri;
        const name = card.dataset.feedName;
        if (uri) loadCustomFeedView(uri, name);
      });
    });

    // Squad add-from-post button
    document.querySelectorAll('.bsky-squad-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        if (!token) return alert('Sign in to manage squads');
        const handle = btn.dataset.handle;
        // Remove any existing dropdown
        document.querySelectorAll('.squad-picker').forEach(el => el.remove());
        try {
          const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, { headers: { Authorization: `Bearer ${token}` } });
          const squads = await res.json();
          if (!squads.length) return alert('Create a squad first in the Squads tab');
          const picker = document.createElement('div');
          picker.className = 'squad-picker';
          picker.style.cssText = 'position:absolute;right:0;top:100%;z-index:50;background:var(--ps-card-bg);border:1px solid var(--ps-card-border);border-radius:.5rem;padding:.25rem 0;min-width:10rem;box-shadow:0 4px 12px rgba(0,0,0,.3)';
          squads.forEach(sq => {
            const item = document.createElement('button');
            item.style.cssText = 'display:block;width:100%;text-align:left;padding:.5rem .75rem;background:none;border:none;color:var(--ps-text);cursor:pointer;font-size:.8rem';
            item.textContent = sq.name;
            item.addEventListener('mouseenter', () => item.style.background = 'var(--ps-surface-hover, rgba(255,255,255,.1))');
            item.addEventListener('mouseleave', () => item.style.background = 'none');
            item.addEventListener('click', async () => {
              picker.remove();
              const addRes = await fetch(`${hubUrl}/api/bluesky-feed/squads/${sq.id}/members`, {
                method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body: JSON.stringify({ handle }),
              });
              if (addRes.ok) { btn.style.color = 'var(--ps-accent, #22c55e)'; }
              else { const err = await addRes.json().catch(() => ({})); alert(err.error || 'Failed to add'); }
            });
            picker.appendChild(item);
          });
          btn.style.position = 'relative';
          btn.appendChild(picker);
          const closePicker = (ev) => { if (!picker.contains(ev.target) && ev.target !== btn) { picker.remove(); document.removeEventListener('click', closePicker); } };
          setTimeout(() => document.addEventListener('click', closePicker), 0);
        } catch (err) { console.error('Squad picker error:', err); }
      });
    });
  }

  // ============================================================
  // SHARE MODAL
  // ============================================================
  const shareOverlay = document.createElement('div');
  shareOverlay.id = 'share-modal-overlay';
  shareOverlay.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:60;justify-content:center;align-items:center';
  shareOverlay.innerHTML = `
    <div id="share-modal" style="background:var(--ps-card-bg);border:1px solid var(--ps-card-border);border-radius:.75rem;padding:1.5rem;width:20rem;max-width:90vw">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
        <h3 style="font-weight:600;font-size:1rem">Share</h3>
        <button id="share-close" style="color:var(--ps-text-muted);font-size:1.25rem;cursor:pointer;background:none;border:none">✕</button>
      </div>
      <div id="share-links" style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem"></div>
    </div>`;
  document.body.appendChild(shareOverlay);
  shareOverlay.addEventListener('click', (e) => { if (e.target === shareOverlay) shareOverlay.style.display = 'none'; });
  document.getElementById('share-close').addEventListener('click', () => shareOverlay.style.display = 'none');

  function openShareModal(url, title) {
    const enc = encodeURIComponent;
    const links = [
      { label: '𝕏 Twitter', href: `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}` },
      { label: '📘 Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}` },
      { label: '💼 LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}` },
      { label: '📌 Pinterest', href: `https://pinterest.com/pin/create/button/?url=${enc(url)}&description=${enc(title)}` },
      { label: '🔗 Reddit', href: `https://www.reddit.com/submit?url=${enc(url)}&title=${enc(title)}` },
      { label: '📧 Email', href: `mailto:?subject=${enc(title)}&body=${enc(url)}` },
    ];
    const linksHtml = links.map(l =>
      `<a href="${l.href}" target="_blank" rel="noopener noreferrer" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:var(--ps-input-bg);color:var(--ps-text);font-size:.875rem;text-decoration:none;transition:background .15s" onmouseover="this.style.background='var(--ps-surface-hover)'" onmouseout="this.style.background='var(--ps-input-bg)'">${l.label}</a>`
    ).join('');
    const copyBtn = `<button id="share-copy" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:var(--ps-input-bg);color:var(--ps-text);font-size:.875rem;border:none;cursor:pointer;transition:background .15s;grid-column:span 2">📋 Copy Link</button>`;
    document.getElementById('share-links').innerHTML = linksHtml + copyBtn;
    document.getElementById('share-copy').addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(url); document.getElementById('share-copy').textContent = '✓ Copied!'; setTimeout(() => document.getElementById('share-copy').textContent = '📋 Copy Link', 2000); } catch {}
    });
    shareOverlay.style.display = 'flex';
  }

  // ============================================================
  // HLS VIDEO INIT
  // ============================================================
  function initHlsVideos() {
    document.querySelectorAll('video[data-hls]').forEach(video => {
      if (video._hlsInit) return;
      video._hlsInit = true;
      const src = video.dataset.hls;
      if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = src;
      } else if (typeof Hls !== 'undefined' && Hls.isSupported()) {
        const hls = new Hls();
        hls.loadSource(src);
        hls.attachMedia(video);
      }
    });
  }

  // ============================================================
  // SQUADS (kept from original)
  // ============================================================
  let allSquads = [];
  let squadsInitialized = false;

  async function initSquadsProfile() {
    if (squadsInitialized) return;
    squadsInitialized = true;
    try {
      const session = await ensureBskySession();
      myHandle = session?.handle || null;
      myDid = session?.did || null;
      if (myHandle) {
        const profileRes = await fetchTimeout(`https://public.api.bsky.app/xrpc/app.bsky.actor.getProfile?actor=${encodeURIComponent(myHandle)}`, {}, 8000);
        if (profileRes.ok) { const profile = await profileRes.json(); myAvatar = profile.avatar || null; }
      }
      document.querySelectorAll('.my-center-avatar').forEach(el => {
        if (myAvatar) el.innerHTML = `<img src="${escapeHtml(myAvatar)}" alt="You" class="w-full h-full object-cover" />`;
      });
    } catch {}
  }

  async function renderSquadsView() {
    hasMore = false;
    scrollSentinel.classList.add('hidden');
    initSquadsProfile();

    feedContainer.innerHTML = `
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-4">
          <select id="squad-select" class="flex-1 rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm focus:outline-none focus:border-theme-primary">
            <option value="">Select a squad...</option>
          </select>
          <button id="toggle-create-squad" class="rounded bg-theme-primary px-3 py-2 text-sm font-medium hover:bg-theme-primary transition whitespace-nowrap">+ New</button>
        </div>
        <form id="create-squad-form" class="hidden flex gap-2 mb-4">
          <input type="text" id="squad-name-input" placeholder="Squad name (e.g. Photo Friends)" required
            class="flex-1 rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm focus:outline-none focus:border-theme-primary" />
          <button type="submit" class="rounded bg-theme-primary px-4 py-2 text-sm font-medium hover:bg-theme-primary transition whitespace-nowrap">Create</button>
        </form>
      </div>
      <div id="squads-list"></div>`;

    document.getElementById('toggle-create-squad').addEventListener('click', () => {
      const form = document.getElementById('create-squad-form');
      form.classList.toggle('hidden');
      if (!form.classList.contains('hidden')) document.getElementById('squad-name-input').focus();
    });

    document.getElementById('create-squad-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('squad-name-input');
      const name = input.value.trim();
      if (!name) return;
      try {
        const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, { method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` }, body: JSON.stringify({ name }) });
        if (!res.ok) { const d = await res.json(); alert(d.error); return; }
        input.value = '';
        document.getElementById('create-squad-form').classList.add('hidden');
        loadSquads();
      } catch { alert('Failed to create squad'); }
    });

    document.getElementById('squad-select').addEventListener('change', (e) => showSquad(e.target.value));
    loadSquads();
    isLoading = false;
  }

  function showSquad(id) {
    const container = document.getElementById('squads-list');
    if (!container) return;
    if (!id) { container.innerHTML = '<div class="text-center py-8 text-theme-faint">Select a squad above or create a new one</div>'; return; }
    const squad = allSquads.find(s => String(s.id) === String(id));
    if (!squad) return;
    container.innerHTML = renderSquad(squad);
    attachSquadListeners();
    initHlsVideos();
    applyCachedActivity(squad);
  }

  async function loadSquads() {
    const container = document.getElementById('squads-list');
    const select = document.getElementById('squad-select');
    if (!container || !select) return;
    try {
      const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, { headers: { Authorization: `Bearer ${token}` } });
      allSquads = await res.json();
      const prevId = select.value;
      select.innerHTML = '<option value="">Select a squad...</option>' + allSquads.map(s => `<option value="${s.id}">${escapeHtml(s.name)} (${s.members.length})</option>`).join('');
      if (!allSquads.length) { container.innerHTML = '<div class="text-center py-8 text-theme-faint">No squads yet. Create one!</div>'; return; }
      const targetId = prevId && allSquads.find(s => String(s.id) === String(prevId)) ? prevId : String(allSquads[0].id);
      select.value = targetId;
      showSquad(targetId);
    } catch { container.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`; }
  }

  function formatWindow(minutes) {
    if (minutes < 60) return `${minutes}m`;
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return m ? `${h}h ${m}m` : `${h}h`;
  }

  function renderSquad(squad) {
    const windowLabel = formatWindow(squad.activityWindow);
    return `
    <div class="rounded-lg border border-theme-card-border bg-theme-card p-6" data-squad-id="${squad.id}">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">${escapeHtml(squad.name)}</h2>
        <button class="delete-squad-btn text-xs text-red-400 hover:text-red-300 transition" data-squad-id="${squad.id}">Delete</button>
      </div>
      <div class="mb-4 flex items-center gap-3">
        <label class="text-xs text-theme-faint whitespace-nowrap">Activity window:</label>
        <input type="range" min="15" max="720" step="15" value="${squad.activityWindow}" class="flex-1 accent-blue-500 squad-window-slider" data-squad-id="${squad.id}" />
        <span class="text-xs text-theme-muted w-16 text-right squad-window-label" data-squad-id="${squad.id}">${windowLabel}</span>
      </div>
      <div class="squad-circle relative flex justify-center items-center my-6" style="min-height:16rem">
        <div class="my-center-avatar absolute rounded-full border-2 border-blue-500 overflow-hidden bg-theme-input-bg flex items-center justify-center" style="width:4rem;height:4rem;z-index:2">
          ${myAvatar ? `<img src="${escapeHtml(myAvatar)}" alt="You" class="w-full h-full object-cover" />` : `<span class="text-lg">👤</span>`}
        </div>
        ${squad.members.map((m, i) => {
          const count = squad.members.length;
          const angle = (2 * Math.PI * i / count) - Math.PI / 2;
          const radius = 100;
          const x = Math.cos(angle) * radius;
          const y = Math.sin(angle) * radius;
          return `
          <div class="absolute squad-member-avatar" data-member-id="${m.id}" data-handle="${escapeHtml(m.handle)}" style="transform:translate(${x}px,${y}px);z-index:1">
            <div class="relative group cursor-pointer">
              <div class="activity-dot absolute -top-1 -right-1 w-3 h-3 rounded-full border-2 border-theme-card bg-theme-surface-hover z-10" data-member-id="${m.id}"></div>
              ${m.avatarUrl ? `<img src="${escapeHtml(m.avatarUrl)}" alt="${escapeHtml(m.displayName || m.handle)}" class="w-12 h-12 rounded-full border-2 border-theme-input-border hover:border-theme-card-hover transition" />` : `<div class="w-12 h-12 rounded-full border-2 border-theme-input-border bg-theme-input-bg flex items-center justify-center text-theme-muted text-xs">${escapeHtml((m.handle || '?')[0].toUpperCase())}</div>`}
              <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-xs text-theme-faint whitespace-nowrap opacity-0 group-hover:opacity-100 transition pointer-events-none">${escapeHtml(m.displayName || m.handle)}</div>
            </div>
          </div>`;
        }).join('')}
      </div>
      <div class="flex gap-2 mt-4">
        <input type="text" placeholder="@handle.bsky.social" class="add-member-input flex-1 rounded bg-theme-input-bg border border-theme-input-border px-3 py-1.5 text-sm focus:outline-none focus:border-theme-primary" data-squad-id="${squad.id}" />
        <button class="add-member-btn rounded bg-theme-surface-hover px-3 py-1.5 text-sm hover:bg-theme-card-hover transition" data-squad-id="${squad.id}">Add</button>
      </div>
      <div class="mt-3 flex flex-wrap gap-1">
        ${squad.members.map(m => `
          <span class="inline-flex items-center gap-1 rounded bg-theme-input-bg px-2 py-0.5 text-xs text-theme-muted">
            @${escapeHtml(m.handle)}
            <button class="remove-member-btn text-theme-faint hover:text-red-400 transition" data-squad-id="${squad.id}" data-member-id="${m.id}">✕</button>
          </span>
        `).join('')}
      </div>
      ${squad.members.length ? `
      <div class="flex gap-2 mt-4">
        <button class="check-activity-btn flex-1 rounded bg-theme-input-bg py-2 text-sm hover:bg-theme-surface-hover transition" data-squad-id="${squad.id}">Check Activity</button>
        <button class="view-squad-feed-btn flex-1 rounded bg-theme-input-bg py-2 text-sm hover:bg-theme-surface-hover transition" data-squad-id="${squad.id}">View Squad Feed</button>
      </div>
      <div class="squad-feed hidden mt-4 space-y-4" data-squad-id="${squad.id}"></div>
      ` : ''}
    </div>`;
  }

  function applyCachedActivity(squad) {
    const cutoff = new Date(Date.now() - squad.activityWindow * 60 * 1000);
    squad.members.forEach(m => {
      const dot = document.querySelector(`.activity-dot[data-member-id="${m.id}"]`);
      if (!dot) return;
      if (m.lastPostAt && new Date(m.lastPostAt) >= cutoff) {
        dot.classList.remove('bg-theme-surface-hover'); dot.classList.add('bg-green-500');
        dot.title = `Last posted ${timeAgo(m.lastPostAt)} (cached)`;
      } else {
        dot.title = m.lastPostAt ? `Last posted ${timeAgo(m.lastPostAt)} (cached)` : 'No data yet';
      }
    });
  }

  async function checkSquadActivity(squadId) {
    const squad = allSquads.find(s => String(s.id) === String(squadId));
    if (!squad?.members.length) return;
    const cutoff = new Date(Date.now() - squad.activityWindow * 60 * 1000);
    const results = await Promise.allSettled(
      squad.members.map(async (m) => {
        const url = `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${encodeURIComponent(m.did || m.handle)}&limit=1&filter=posts_no_replies`;
        const res = await fetch(url);
        if (!res.ok) return { id: m.id, lastPostAt: null, isActive: false };
        const data = await res.json();
        const lastPost = data.feed?.[0]?.post;
        const lastPostAt = lastPost ? lastPost.indexedAt : null;
        return { id: m.id, lastPostAt, isActive: lastPostAt ? new Date(lastPostAt) >= cutoff : false };
      })
    );
    results.forEach(r => {
      if (r.status !== 'fulfilled') return;
      const m = r.value;
      const dot = document.querySelector(`.activity-dot[data-member-id="${m.id}"]`);
      if (!dot) return;
      if (m.isActive) { dot.classList.remove('bg-theme-surface-hover'); dot.classList.add('bg-green-500'); dot.title = `Last posted ${timeAgo(m.lastPostAt)}`; }
      else { dot.classList.remove('bg-green-500'); dot.classList.add('bg-theme-surface-hover'); dot.title = m.lastPostAt ? `Last posted ${timeAgo(m.lastPostAt)}` : 'No recent posts'; }
    });
  }

  async function fetchSquadFeedDirect(members) {
    const results = await Promise.allSettled(members.map(m => {
      return (async () => {
        const url = `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${encodeURIComponent(m.did || m.handle)}&limit=5&filter=posts_and_author_threads`;
        const res = await fetchTimeout(url, {}, 8000);
        if (!res.ok) throw new Error(`API ${res.status}`);
        const data = await res.json();
        return (data.feed || []).map(item => normalizeBskyPost(item));
      })();
    }));
    return results.filter(r => r.status === 'fulfilled').flatMap(r => r.value).sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));
  }

  function attachSquadListeners() {
    document.querySelectorAll('.squad-window-slider').forEach(slider => {
      slider.addEventListener('input', () => {
        const label = document.querySelector(`.squad-window-label[data-squad-id="${slider.dataset.squadId}"]`);
        if (label) label.textContent = formatWindow(parseInt(slider.value));
      });
      slider.addEventListener('change', async () => {
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${slider.dataset.squadId}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` }, body: JSON.stringify({ activityWindow: parseInt(slider.value) }) });
      });
    });

    document.querySelectorAll('.check-activity-btn').forEach(btn => {
      btn.addEventListener('click', async () => { btn.textContent = 'Checking...'; btn.disabled = true; await checkSquadActivity(btn.dataset.squadId); btn.textContent = 'Check Activity'; btn.disabled = false; });
    });

    document.querySelectorAll('.delete-squad-btn').forEach(btn => {
      btn.addEventListener('click', async () => { if (!confirm('Delete this squad?')) return; await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } }); loadSquads(); });
    });

    document.querySelectorAll('.add-member-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const input = document.querySelector(`.add-member-input[data-squad-id="${btn.dataset.squadId}"]`);
        const handle = input.value.trim();
        if (!handle) return;
        btn.textContent = '...'; btn.disabled = true;
        try {
          const res = await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}/members`, { method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` }, body: JSON.stringify({ handle }) });
          if (!res.ok) { const d = await res.json(); alert(d.error); return; }
          input.value = '';
          loadSquads();
        } catch { alert('Failed to add member'); }
        finally { btn.textContent = 'Add'; btn.disabled = false; }
      });
    });

    document.querySelectorAll('.remove-member-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}/members/${btn.dataset.memberId}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } });
        loadSquads();
      });
    });

    document.querySelectorAll('.view-squad-feed-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const feedEl = document.querySelector(`.squad-feed[data-squad-id="${btn.dataset.squadId}"]`);
        if (!feedEl.classList.contains('hidden')) { feedEl.classList.add('hidden'); btn.textContent = 'View Squad Feed'; return; }
        const squad = allSquads.find(s => String(s.id) === btn.dataset.squadId);
        if (!squad?.members.length) return;
        btn.textContent = L.loading || 'Loading...';
        try {
          const posts = await fetchSquadFeedDirect(squad.members);
          feedEl.innerHTML = posts.map(p => renderPostCard(p)).join('') || `<div class="text-center py-4 text-theme-faint">${L.noPosts || 'No posts'}</div>`;
          feedEl.classList.remove('hidden');
          btn.textContent = 'Hide Squad Feed';
          attachAllListeners();
          initHlsVideos();
        } catch {
          feedEl.innerHTML = `<div class="text-center py-4 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
          feedEl.classList.remove('hidden');
          btn.textContent = 'Hide Squad Feed';
        }
      });
    });

    document.querySelectorAll('.squad-member-avatar').forEach(el => {
      el.addEventListener('click', () => openProfile(el.dataset.handle));
    });
  }

  // ============================================================
  // INIT
  // ============================================================
  if (token) {
    initSquadsProfile();
    updateUI();
    loadCurrentTab();
  } else {
    updateUI();
    loadFeedTab();
  }
</script>

