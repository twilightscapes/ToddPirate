  function showSquad(id) {
    const container = document.getElementById('squads-list');
    if (!container) return;
    if (!id) { container.innerHTML = '<div class="text-center py-8 text-theme-faint">Select a squad above or create a new one</div>'; return; }
    const squad = allSquads.find(s => String(s.id) === String(id));
    if (!squad) return;
    container.innerHTML = renderSquad(squad);
    attachSquadListeners();
    initHlsVideos();
    applyCachedActivity(squad);
  }

  async function loadSquads() {
    const container = document.getElementById('squads-list');
    const select = document.getElementById('squad-select');
    if (!container || !select) return;
    try {
      const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, { headers: { Authorization: `Bearer ${token}` } });
      allSquads = await res.json();
      const prevId = select.value;
      select.innerHTML = '<option value="">Select a squad...</option>' + allSquads.map(s => `<option value="${s.id}">${escapeHtml(s.name)} (${s.members.length})</option>`).join('');
      if (!allSquads.length) { container.innerHTML = '<div class="text-center py-8 text-theme-faint">No squads yet. Create one!</div>'; return; }
      const targetId = prevId && allSquads.find(s => String(s.id) === String(prevId)) ? prevId : String(allSquads[0].id);
      select.value = targetId;
      showSquad(targetId);
    } catch { container.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`; }
  }

  function formatWindow(minutes) {
    if (minutes < 60) return `${minutes}m`;
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return m ? `${h}h ${m}m` : `${h}h`;
  }

