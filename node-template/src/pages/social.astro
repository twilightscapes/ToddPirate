---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/config';
---

<BaseLayout title="Social">
  <div class="mx-auto max-w-3xl">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="text-2xl font-bold">Social Feed</h1>
      <div class="flex gap-2 flex-wrap">
        <button id="tab-squads" class="rounded bg-zinc-800 px-3 py-1.5 text-sm hover:bg-zinc-700 transition">
          Squads
        </button>
        <button id="tab-timeline" class="rounded bg-zinc-800 px-3 py-1.5 text-sm hover:bg-zinc-700 transition active-tab">
          Timeline
        </button>
        <button id="tab-bluesky" class="rounded bg-zinc-800 px-3 py-1.5 text-sm hover:bg-zinc-700 transition">
          Bluesky
        </button>
        <button id="tab-discover" class="rounded bg-zinc-800 px-3 py-1.5 text-sm hover:bg-zinc-700 transition">
          Discover
        </button>
        <button id="tab-people" class="rounded bg-zinc-800 px-3 py-1.5 text-sm hover:bg-zinc-700 transition">
          People
        </button>
      </div>
    </div>

    <!-- Timeline container -->
    <div id="feed-container" class="space-y-6">
      <div class="text-center text-zinc-500 py-12">
        <p>Sign in to see your timeline</p>
        <button id="social-login" class="mt-4 rounded bg-white text-black px-4 py-2 text-sm font-medium hover:bg-zinc-200 transition">
          Sign in with GitHub
        </button>
      </div>
    </div>

    <!-- Load more -->
    <div id="load-more-container" class="mt-8 text-center hidden">
      <button id="load-more" class="rounded bg-zinc-800 px-6 py-2 text-sm hover:bg-zinc-700 transition">
        Load More
      </button>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ hubUrl: siteConfig.hubUrl }}>
  const token = localStorage.getItem('ps_token');
  const feedContainer = document.getElementById('feed-container');
  const loadMoreBtn = document.getElementById('load-more');
  const loadMoreContainer = document.getElementById('load-more-container');

  let currentPage = 1;
  let currentTab = 'timeline';
  let bskyCursor = null;

  // Tab switching
  document.querySelectorAll('[id^="tab-"]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelector('.active-tab')?.classList.remove('active-tab', 'bg-zinc-600');
      btn.classList.add('active-tab', 'bg-zinc-600');
      currentTab = btn.id.replace('tab-', '');
      currentPage = 1;
      bskyCursor = null;
      loadFeed();
    });
  });

  // Login button
  document.getElementById('social-login')?.addEventListener('click', () => {
    window.location.href = `${hubUrl}/api/auth/github`;
  });

  async function loadFeed(append = false) {
    if (!append) feedContainer.innerHTML = '<div class="text-center py-8 text-zinc-500">Loading...</div>';

    try {
      let url;
      const headers = token ? { Authorization: `Bearer ${token}` } : {};

      if (currentTab === 'squads' && token) {
        renderSquadsView();
        return;
      } else if (currentTab === 'timeline' && token) {
        url = `${hubUrl}/api/timeline?page=${currentPage}`;
      } else if (currentTab === 'bluesky' && token) {
        url = `${hubUrl}/api/bluesky-feed/timeline${bskyCursor ? `?cursor=${encodeURIComponent(bskyCursor)}` : ''}`;
        const res = await fetch(url, { headers });
        const data = await res.json();
        renderBskyPosts(data, append);
        return;
      } else if (currentTab === 'discover' || (currentTab === 'timeline' && !token)) {
        url = `${hubUrl}/api/timeline/discover?page=${currentPage}`;
      } else if (currentTab === 'people') {
        url = `${hubUrl}/api/directory?page=${currentPage}`;
        const res = await fetch(url, { headers });
        const data = await res.json();
        renderPeople(data, append);
        return;
      }

      const res = await fetch(url, { headers });
      const data = await res.json();
      renderPosts(data, append);
    } catch (err) {
      feedContainer.innerHTML = '<div class="text-center py-8 text-red-400">Failed to load feed</div>';
    }
  }

  function renderPosts(data, append) {
    const html = (data.posts || []).map(post => {
      const isExternal = post.source === 'external';

      // Author line: Pirate user or external feed info
      const authorHtml = isExternal
        ? `<div class="flex items-center gap-2">
            ${post.feed?.iconUrl ? `<img src="${escapeHtml(post.feed.iconUrl)}" class="h-8 w-8 rounded" onerror="this.style.display='none'" />` : '<div class="h-8 w-8 rounded bg-zinc-700 flex items-center justify-center text-zinc-400 text-xs">RSS</div>'}
            <div>
              <span class="font-medium text-sm">${escapeHtml(post.feed?.title || post.author || 'External')}</span>
              <span class="ml-2 text-xs px-1.5 py-0.5 rounded bg-zinc-800 text-zinc-400">RSS</span>
              <time class="block text-xs text-zinc-500">${new Date(post.pubDate).toLocaleDateString()}</time>
            </div>
          </div>`
        : `<div class="flex items-center gap-3">
            ${post.user?.avatarUrl ? `<img src="${escapeHtml(post.user.avatarUrl)}" class="h-8 w-8 rounded-full" />` : ''}
            <div>
              <a href="${hubUrl}/../${escapeHtml(post.user?.username || '')}" class="font-medium text-sm hover:underline">${escapeHtml(post.user?.displayName || post.user?.username || 'Unknown')}</a>
              <time class="block text-xs text-zinc-500">${new Date(post.pubDate).toLocaleDateString()}</time>
            </div>
          </div>`;

      // Interaction bar: only Pirate posts have likes/comments
      const shareBtn = `<button class="share-btn hover:text-green-400 transition" data-url="${escapeHtml(post.link || '')}" data-title="${escapeHtml(post.title || '')}">↗ Share</button>`;
      const actionsHtml = isExternal
        ? `<a href="${escapeHtml(post.link)}" target="_blank" rel="noopener noreferrer" class="hover:text-white">↗ Read</a>${shareBtn}`
        : `<button class="like-btn hover:text-red-400 transition ${post.hasLiked ? 'text-red-400' : ''}" data-post-id="${post.id}">
              ${post.hasLiked ? '♥' : '♡'} ${post.likeCount || post._count?.likes || 0}
            </button>
            <button class="comment-btn hover:text-blue-400 transition" data-post-id="${post.id}">
              💬 ${post.commentCount || post._count?.comments || 0}
            </button>
            ${shareBtn}
            ${post.link ? `<a href="${escapeHtml(post.link)}" target="_blank" class="hover:text-white ml-auto">↗ View</a>` : ''}`;

      // Build embed HTML for rich content (Bluesky images, videos, link cards, quotes)
      const embed = post.embedData || {};
      let embedHtml = '';

      // Multiple images (gallery grid)
      if (embed.images?.length > 1) {
        embedHtml += `<div class="grid grid-cols-2 gap-1 mt-2 rounded overflow-hidden">
          ${embed.images.map(img => `<img src="${escapeHtml(img.fullsize || img.thumb)}" alt="${escapeHtml(img.alt)}" class="w-full object-cover aspect-square" loading="lazy" onerror="this.style.display='none'" />`).join('')}
        </div>`;
      }

      // Video
      if (embed.video?.playlist) {
        embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video relative">
          <video controls preload="none" poster="${escapeHtml(embed.video.thumb || '')}" class="w-full h-full">
            <source src="${escapeHtml(embed.video.playlist)}" type="application/x-mpegURL" />
          </video>
        </div>`;
      }

      // External link card
      if (embed.external?.uri) {
        embedHtml += `<a href="${escapeHtml(embed.external.uri)}" target="_blank" rel="noopener noreferrer" class="mt-2 block rounded border border-zinc-700 overflow-hidden hover:border-zinc-500 transition">
          ${embed.external.thumb ? `<img src="${escapeHtml(embed.external.thumb)}" alt="" class="w-full aspect-[2/1] object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
          <div class="p-3">
            <div class="text-sm font-medium text-zinc-200 line-clamp-1">${escapeHtml(embed.external.title || '')}</div>
            ${embed.external.description ? `<div class="text-xs text-zinc-500 mt-1 line-clamp-2">${escapeHtml(embed.external.description)}</div>` : ''}
            <div class="text-xs text-zinc-600 mt-1">${escapeHtml(new URL(embed.external.uri).hostname)}</div>
          </div>
        </a>`;
      }

      // Quote post
      if (embed.quote?.text) {
        embedHtml += `<div class="mt-2 rounded border border-zinc-700 p-3 bg-zinc-800/50">
          <div class="text-xs text-zinc-400 mb-1">
            <span class="font-medium text-zinc-300">${escapeHtml(embed.quote.author)}</span>
            <span class="text-zinc-500 ml-1">@${escapeHtml(embed.quote.handle)}</span>
          </div>
          <p class="text-sm text-zinc-300 line-clamp-4">${escapeHtml(embed.quote.text)}</p>
        </div>`;
      }

      // Primary image: use single embed image or imageUrl (skip if we showed a gallery above)
      const primaryImage = (embed.images?.length === 1)
        ? embed.images[0].fullsize || embed.images[0].thumb
        : (!embed.images?.length ? post.imageUrl : null);

      return `
        <article class="rounded-lg border border-zinc-800 bg-zinc-900 overflow-hidden">
          ${primaryImage ? `<div class="bg-black flex justify-center"><img src="${escapeHtml(primaryImage)}" alt="${escapeHtml(embed.images?.[0]?.alt || post.title)}" style="width:100%;max-height:28rem;object-fit:contain" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>` : ''}
          <div class="p-4">
            <div class="mb-3">${authorHtml}</div>
            <h3 class="font-semibold"><a href="${escapeHtml(post.link)}" target="_blank" class="hover:underline">${formatText(post.title)}</a></h3>
            ${post.description && post.description !== post.title ? `<p class="mt-1 text-sm text-zinc-400">${formatText(post.description)}</p>` : ''}
            ${embedHtml}
            ${post.exifData ? `<div class="mt-2 text-xs text-zinc-500">${formatExif(post.exifData)}</div>` : ''}
            <div class="mt-3 flex items-center gap-4 text-sm text-zinc-400">
              ${actionsHtml}
            </div>
          </div>
        </article>
      `;
    }).join('');

    if (append) {
      feedContainer.insertAdjacentHTML('beforeend', html);
    } else {
      feedContainer.innerHTML = html || '<div class="text-center py-8 text-zinc-500">No posts yet</div>';
    }

    loadMoreContainer.classList.toggle('hidden', !data.hasMore);
    attachInteractionListeners();
    attachShareListeners();
  }

  function renderBskyPosts(data, append) {
    const posts = data.posts || [];
    bskyCursor = data.cursor || null;

    const html = posts.map(post => {
      const embed = post.embedData || {};
      let embedHtml = '';

      // Multiple images
      if (embed.images?.length > 1) {
        embedHtml += `<div class="grid grid-cols-2 gap-1 mt-2 rounded overflow-hidden">
          ${embed.images.map(img => `<img src="${escapeHtml(img.fullsize || img.thumb)}" alt="${escapeHtml(img.alt || '')}" class="w-full object-cover aspect-square" loading="lazy" onerror="this.style.display='none'" />`).join('')}
        </div>`;
      }

      // Single image
      if (embed.images?.length === 1) {
        embedHtml += `<div class="mt-2 bg-black flex justify-center rounded overflow-hidden"><img src="${escapeHtml(embed.images[0].fullsize || embed.images[0].thumb)}" alt="${escapeHtml(embed.images[0].alt || '')}" style="width:100%;max-height:28rem;object-fit:contain" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>`;
      }

      // Video
      if (embed.video?.playlist) {
        embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video">
          <video controls preload="none" poster="${escapeHtml(embed.video.thumb || '')}" class="w-full h-full">
            <source src="${escapeHtml(embed.video.playlist)}" type="application/x-mpegURL" />
          </video>
        </div>`;
      }

      // External link card
      if (embed.external?.uri) {
        embedHtml += `<a href="${escapeHtml(embed.external.uri)}" target="_blank" rel="noopener noreferrer" class="mt-2 block rounded border border-zinc-700 overflow-hidden hover:border-zinc-500 transition">
          ${embed.external.thumb ? `<img src="${escapeHtml(embed.external.thumb)}" alt="" class="w-full aspect-[2/1] object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
          <div class="p-3">
            <div class="text-sm font-medium text-zinc-200 line-clamp-1">${escapeHtml(embed.external.title || '')}</div>
            ${embed.external.description ? `<div class="text-xs text-zinc-500 mt-1 line-clamp-2">${escapeHtml(embed.external.description)}</div>` : ''}
          </div>
        </a>`;
      }

      // Quote
      if (embed.quote?.text) {
        embedHtml += `<div class="mt-2 rounded border border-zinc-700 p-3 bg-zinc-800/50">
          <div class="text-xs text-zinc-400 mb-1">
            <span class="font-medium text-zinc-300">${escapeHtml(embed.quote.author)}</span>
            <span class="text-zinc-500 ml-1">@${escapeHtml(embed.quote.handle)}</span>
          </div>
          <p class="text-sm text-zinc-300 line-clamp-4">${escapeHtml(embed.quote.text)}</p>
        </div>`;
      }

      const repostLine = post.repostBy
        ? `<div class="text-xs text-zinc-500 mb-2">🔁 Reposted by ${escapeHtml(post.repostBy.displayName)}</div>`
        : '';

      return `
        <article class="rounded-lg border border-zinc-800 bg-zinc-900 overflow-hidden">
          <div class="p-4">
            ${repostLine}
            <div class="flex items-center gap-3 mb-3">
              ${post.author.avatar ? `<img src="${escapeHtml(post.author.avatar)}" class="h-10 w-10 rounded-full" />` : '<div class="h-10 w-10 rounded-full bg-zinc-700"></div>'}
              <div>
                <a href="https://bsky.app/profile/${escapeHtml(post.author.handle)}" target="_blank" class="font-medium text-sm hover:underline">${escapeHtml(post.author.displayName)}</a>
                <div class="text-xs text-zinc-500">@${escapeHtml(post.author.handle)}</div>
              </div>
              <time class="text-xs text-zinc-500 ml-auto">${new Date(post.pubDate).toLocaleDateString()}</time>
            </div>
            ${post.text ? `<p class="text-sm whitespace-pre-wrap mb-2">${formatText(post.text)}</p>` : ''}
            ${embedHtml}
            <div class="mt-3 flex items-center gap-4 text-xs text-zinc-500">
              <span>♡ ${post.likeCount}</span>
              <span>🔁 ${post.repostCount}</span>
              <span>💬 ${post.replyCount}</span>
              <button class="share-btn hover:text-green-400 transition ml-auto" data-url="${escapeHtml(post.link)}" data-title="${escapeHtml(post.text?.slice(0, 100) || '')}">↗ Share</button>
              <a href="${escapeHtml(post.link)}" target="_blank" rel="noopener noreferrer" class="hover:text-white">↗ Open</a>
            </div>
          </div>
        </article>
      `;
    }).join('');

    if (append) {
      feedContainer.insertAdjacentHTML('beforeend', html);
    } else {
      feedContainer.innerHTML = html || '<div class="text-center py-8 text-zinc-500">Connect your Bluesky account in Settings to see your feed</div>';
    }

    loadMoreContainer.classList.toggle('hidden', !bskyCursor);
    attachShareListeners();
  }

  function renderPeople(data, append) {
    const html = (data.users || []).map(user => `
      <div class="flex items-center gap-4 rounded-lg border border-zinc-800 bg-zinc-900 p-4">
        ${user.avatarUrl ? `<img src="${escapeHtml(user.avatarUrl)}" class="h-12 w-12 rounded-full" />` : '<div class="h-12 w-12 rounded-full bg-zinc-700"></div>'}
        <div class="flex-1 min-w-0">
          <a href="${escapeHtml(user.siteUrl || '#')}" target="_blank" class="font-medium hover:underline">${escapeHtml(user.displayName || user.username)}</a>
          <p class="text-sm text-zinc-400">@${escapeHtml(user.username)}</p>
          ${user.bio ? `<p class="text-sm text-zinc-500 mt-1 truncate">${escapeHtml(user.bio)}</p>` : ''}
        </div>
        <div class="text-right text-xs text-zinc-500">
          <div>${user._count?.posts || 0} posts</div>
          <div>${user._count?.followers || 0} followers</div>
        </div>
        ${token ? `<button class="follow-btn rounded bg-zinc-700 px-3 py-1 text-xs hover:bg-zinc-600 transition" data-user-id="${user.id}">Follow</button>` : ''}
      </div>
    `).join('');

    if (append) {
      feedContainer.insertAdjacentHTML('beforeend', html);
    } else {
      feedContainer.innerHTML = html || '<div class="text-center py-8 text-zinc-500">No users yet</div>';
    }

    loadMoreContainer.classList.toggle('hidden', !data.hasMore);
    attachInteractionListeners();
    attachShareListeners();
  }

  function attachInteractionListeners() {
    document.querySelectorAll('.like-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!token) return alert('Sign in to like posts');
        const postId = btn.dataset.postId;
        const isLiked = btn.textContent.includes('♥');
        const method = isLiked ? 'DELETE' : 'POST';
        const res = await fetch(`${hubUrl}/api/interactions/like`, {
          method, headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId }),
        });
        const data = await res.json();
        btn.innerHTML = `${data.liked ? '♥' : '♡'} ${data.count}`;
        btn.classList.toggle('text-red-400', data.liked);
      });
    });

    document.querySelectorAll('.follow-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!token) return;
        const userId = btn.dataset.userId;
        const res = await fetch(`${hubUrl}/api/interactions/follow`, {
          method: 'POST', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId }),
        });
        const data = await res.json();
        btn.textContent = data.following ? 'Following' : 'Follow';
      });
    });
  }

  function formatExif(exif) {
    const parts = [];
    if (exif.camera) parts.push(exif.camera);
    if (exif.lens) parts.push(exif.lens);
    if (exif.focalLength) parts.push(exif.focalLength);
    if (exif.aperture) parts.push(`f/${exif.aperture}`);
    if (exif.shutterSpeed) parts.push(`${exif.shutterSpeed}s`);
    if (exif.iso) parts.push(`ISO ${exif.iso}`);
    return parts.join(' · ');
  }

  function escapeHtml(str) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function formatText(str) {
    if (!str) return '';
    // Decode XML newline entities, strip Bluesky embed placeholders
    let text = str
      .replace(/&#xA;/gi, '\n')
      .replace(/\[contains quote post or other embedded content\]/gi, '')
      .trim();
    return escapeHtml(text).replace(/\n/g, '<br>');
  }

  // Load more
  loadMoreBtn?.addEventListener('click', () => {
    currentPage++;
    loadFeed(true);
  });

  // --- Share modal ---
  const shareOverlay = document.createElement('div');
  shareOverlay.id = 'share-modal-overlay';
  shareOverlay.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:50;justify-content:center;align-items:center';
  shareOverlay.innerHTML = `
    <div id="share-modal" style="background:#18181b;border:1px solid #3f3f46;border-radius:.75rem;padding:1.5rem;width:20rem;max-width:90vw">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
        <h3 style="font-weight:600;font-size:1rem">Share</h3>
        <button id="share-close" style="color:#a1a1aa;font-size:1.25rem;cursor:pointer;background:none;border:none">✕</button>
      </div>
      <div id="share-links" style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem"></div>
    </div>`;
  document.body.appendChild(shareOverlay);

  shareOverlay.addEventListener('click', (e) => { if (e.target === shareOverlay) shareOverlay.style.display = 'none'; });
  document.getElementById('share-close').addEventListener('click', () => shareOverlay.style.display = 'none');

  function openShareModal(url, title) {
    const enc = encodeURIComponent;
    const links = [
      { label: '𝕏 Twitter', href: `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}` },
      { label: '📘 Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}` },
      { label: '💼 LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}` },
      { label: '📌 Pinterest', href: `https://pinterest.com/pin/create/button/?url=${enc(url)}&description=${enc(title)}` },
      { label: '🔗 Reddit', href: `https://www.reddit.com/submit?url=${enc(url)}&title=${enc(title)}` },
      { label: '📧 Email', href: `mailto:?subject=${enc(title)}&body=${enc(url)}` },
    ];
    const linksHtml = links.map(l =>
      `<a href="${l.href}" target="_blank" rel="noopener noreferrer" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:#27272a;color:#e4e4e7;font-size:.875rem;text-decoration:none;transition:background .15s" onmouseover="this.style.background='#3f3f46'" onmouseout="this.style.background='#27272a'">${l.label}</a>`
    ).join('');
    const copyBtn = `<button id="share-copy" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:#27272a;color:#e4e4e7;font-size:.875rem;border:none;cursor:pointer;transition:background .15s;grid-column:span 2" onmouseover="this.style.background='#3f3f46'" onmouseout="this.style.background='#27272a'">📋 Copy Link</button>`;
    document.getElementById('share-links').innerHTML = linksHtml + copyBtn;
    document.getElementById('share-copy').addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url);
        document.getElementById('share-copy').textContent = '✓ Copied!';
        setTimeout(() => document.getElementById('share-copy').textContent = '📋 Copy Link', 2000);
      } catch { /* fallback */ }
    });
    shareOverlay.style.display = 'flex';
  }

  function attachShareListeners() {
    document.querySelectorAll('.share-btn').forEach(btn => {
      btn.addEventListener('click', () => openShareModal(btn.dataset.url, btn.dataset.title));
    });
  }

  // === SQUADS ===
  let myAvatar = null;
  let myHandle = null;
  let squadsInitialized = false;

  async function initSquadsProfile() {
    if (squadsInitialized) return;
    squadsInitialized = true;
    try {
      const bskyRes = await fetch(`${hubUrl}/api/bluesky/status`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      const bskyData = await bskyRes.json();
      myHandle = bskyData.handle;
      if (myHandle) {
        const profileRes = await fetch(`https://public.api.bsky.app/xrpc/app.bsky.actor.getProfile?actor=${encodeURIComponent(myHandle)}`);
        if (profileRes.ok) {
          const profile = await profileRes.json();
          myAvatar = profile.avatar || null;
        }
      }
    } catch {}
  }

  async function renderSquadsView() {
    loadMoreContainer.classList.add('hidden');
    await initSquadsProfile();

    feedContainer.innerHTML = `
      <div class="mb-6">
        <p class="text-zinc-400 text-sm mb-4">Create groups of Bluesky users. See who's active at a glance and browse their posts.</p>
        <form id="create-squad-form" class="flex gap-2">
          <input type="text" id="squad-name-input" placeholder="Squad name (e.g. Photo Friends)" required
            class="flex-1 rounded bg-zinc-800 border border-zinc-700 px-3 py-2 text-sm focus:outline-none focus:border-blue-500" />
          <button type="submit" class="rounded bg-blue-600 px-4 py-2 text-sm font-medium hover:bg-blue-500 transition whitespace-nowrap">
            Create Squad
          </button>
        </form>
      </div>
      <div id="squads-list" class="space-y-8"></div>`;

    document.getElementById('create-squad-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('squad-name-input');
      const name = input.value.trim();
      if (!name) return;
      try {
        const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ name }),
        });
        if (!res.ok) { const d = await res.json(); alert(d.error); return; }
        input.value = '';
        loadSquads();
      } catch { alert('Failed to create squad'); }
    });

    loadSquads();
  }

  async function loadSquads() {
    const container = document.getElementById('squads-list');
    if (!container) return;
    try {
      const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      const squads = await res.json();
      if (!squads.length) {
        container.innerHTML = '<div class="text-center py-8 text-zinc-500">No squads yet. Create one above!</div>';
        return;
      }
      container.innerHTML = squads.map(squad => renderSquad(squad)).join('');
      attachSquadListeners();
      squads.forEach(squad => checkSquadActivity(squad.id));
    } catch {
      container.innerHTML = '<div class="text-center py-8 text-red-400">Failed to load squads</div>';
    }
  }

  function renderSquad(squad) {
    const windowLabel = formatWindow(squad.activityWindow);
    return `
    <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-6" data-squad-id="${squad.id}">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">${escapeHtml(squad.name)}</h2>
        <button class="delete-squad-btn text-xs text-red-400 hover:text-red-300 transition" data-squad-id="${squad.id}">Delete</button>
      </div>

      <div class="mb-4 flex items-center gap-3">
        <label class="text-xs text-zinc-500 whitespace-nowrap">Activity window:</label>
        <input type="range" min="15" max="720" step="15" value="${squad.activityWindow}"
          class="flex-1 accent-blue-500 squad-window-slider" data-squad-id="${squad.id}" />
        <span class="text-xs text-zinc-400 w-16 text-right squad-window-label" data-squad-id="${squad.id}">${windowLabel}</span>
      </div>

      <div class="squad-circle relative flex justify-center items-center my-6" style="min-height:16rem">
        <div class="absolute rounded-full border-2 border-blue-500 overflow-hidden bg-zinc-800 flex items-center justify-center" style="width:4rem;height:4rem;z-index:2">
          ${myAvatar
            ? `<img src="${escapeHtml(myAvatar)}" alt="You" class="w-full h-full object-cover" />`
            : `<span class="text-lg">👤</span>`
          }
        </div>
        ${squad.members.map((m, i) => {
          const count = squad.members.length;
          const angle = (2 * Math.PI * i / count) - Math.PI / 2;
          const radius = 100;
          const x = Math.cos(angle) * radius;
          const y = Math.sin(angle) * radius;
          return `
          <div class="absolute squad-member-avatar" data-member-id="${m.id}" data-handle="${escapeHtml(m.handle)}"
            style="transform:translate(${x}px,${y}px);z-index:1">
            <div class="relative group cursor-pointer">
              <div class="activity-dot absolute -top-1 -right-1 w-3 h-3 rounded-full border-2 border-zinc-900 bg-zinc-600 z-10" data-member-id="${m.id}"></div>
              ${m.avatarUrl
                ? `<img src="${escapeHtml(m.avatarUrl)}" alt="${escapeHtml(m.displayName || m.handle)}" class="w-12 h-12 rounded-full border-2 border-zinc-700 hover:border-zinc-500 transition" />`
                : `<div class="w-12 h-12 rounded-full border-2 border-zinc-700 bg-zinc-800 flex items-center justify-center text-zinc-400 text-xs">${escapeHtml((m.handle || '?')[0].toUpperCase())}</div>`
              }
              <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-xs text-zinc-500 whitespace-nowrap opacity-0 group-hover:opacity-100 transition pointer-events-none">
                ${escapeHtml(m.displayName || m.handle)}
              </div>
            </div>
          </div>`;
        }).join('')}
      </div>

      <div class="flex gap-2 mt-4">
        <input type="text" placeholder="@handle.bsky.social" class="add-member-input flex-1 rounded bg-zinc-800 border border-zinc-700 px-3 py-1.5 text-sm focus:outline-none focus:border-blue-500" data-squad-id="${squad.id}" />
        <button class="add-member-btn rounded bg-zinc-700 px-3 py-1.5 text-sm hover:bg-zinc-600 transition" data-squad-id="${squad.id}">Add</button>
      </div>

      <div class="mt-3 flex flex-wrap gap-1">
        ${squad.members.map(m => `
          <span class="inline-flex items-center gap-1 rounded bg-zinc-800 px-2 py-0.5 text-xs text-zinc-400">
            @${escapeHtml(m.handle)}
            <button class="remove-member-btn text-zinc-600 hover:text-red-400 transition" data-squad-id="${squad.id}" data-member-id="${m.id}">✕</button>
          </span>
        `).join('')}
      </div>

      ${squad.members.length ? `
      <button class="view-squad-feed-btn mt-4 w-full rounded bg-zinc-800 py-2 text-sm hover:bg-zinc-700 transition" data-squad-id="${squad.id}">
        View Squad Feed
      </button>
      <div class="squad-feed hidden mt-4 space-y-4" data-squad-id="${squad.id}"></div>
      ` : ''}
    </div>`;
  }

  async function checkSquadActivity(squadId) {
    try {
      const res = await fetch(`${hubUrl}/api/bluesky-feed/squads/${squadId}/activity`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) return;
      const data = await res.json();
      data.members.forEach(m => {
        const dot = document.querySelector(`.activity-dot[data-member-id="${m.id}"]`);
        if (dot) {
          if (m.isActive) {
            dot.classList.remove('bg-zinc-600');
            dot.classList.add('bg-green-500');
            dot.title = `Last posted ${timeAgo(m.lastPostAt)}`;
          } else {
            dot.classList.remove('bg-green-500');
            dot.classList.add('bg-zinc-600');
            dot.title = m.lastPostAt ? `Last posted ${timeAgo(m.lastPostAt)}` : 'No recent posts';
          }
        }
      });
    } catch {}
  }

  function attachSquadListeners() {
    document.querySelectorAll('.squad-window-slider').forEach(slider => {
      slider.addEventListener('input', () => {
        const label = document.querySelector(`.squad-window-label[data-squad-id="${slider.dataset.squadId}"]`);
        if (label) label.textContent = formatWindow(parseInt(slider.value));
      });
      slider.addEventListener('change', async () => {
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${slider.dataset.squadId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ activityWindow: parseInt(slider.value) }),
        });
        checkSquadActivity(slider.dataset.squadId);
      });
    });

    document.querySelectorAll('.delete-squad-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this squad?')) return;
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}`, {
          method: 'DELETE',
          headers: { Authorization: `Bearer ${token}` },
        });
        loadSquads();
      });
    });

    document.querySelectorAll('.add-member-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const input = document.querySelector(`.add-member-input[data-squad-id="${btn.dataset.squadId}"]`);
        const handle = input.value.trim();
        if (!handle) return;
        btn.textContent = '...';
        btn.disabled = true;
        try {
          const res = await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}/members`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
            body: JSON.stringify({ handle }),
          });
          if (!res.ok) { const d = await res.json(); alert(d.error); return; }
          input.value = '';
          loadSquads();
        } catch { alert('Failed to add member'); }
        finally { btn.textContent = 'Add'; btn.disabled = false; }
      });
    });

    document.querySelectorAll('.remove-member-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}/members/${btn.dataset.memberId}`, {
          method: 'DELETE',
          headers: { Authorization: `Bearer ${token}` },
        });
        loadSquads();
      });
    });

    document.querySelectorAll('.view-squad-feed-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const feedEl = document.querySelector(`.squad-feed[data-squad-id="${btn.dataset.squadId}"]`);
        if (!feedEl.classList.contains('hidden')) {
          feedEl.classList.add('hidden');
          btn.textContent = 'View Squad Feed';
          return;
        }
        btn.textContent = 'Loading...';
        try {
          const res = await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}/feed`, {
            headers: { Authorization: `Bearer ${token}` },
          });
          const data = await res.json();
          feedEl.innerHTML = (data.posts || []).map(post => renderSquadCard(post)).join('') || '<div class="text-center py-4 text-zinc-500">No posts</div>';
          feedEl.classList.remove('hidden');
          btn.textContent = 'Hide Squad Feed';
        } catch {
          feedEl.innerHTML = '<div class="text-center py-4 text-red-400">Failed to load</div>';
          feedEl.classList.remove('hidden');
          btn.textContent = 'Hide Squad Feed';
        }
      });
    });

    document.querySelectorAll('.squad-member-avatar').forEach(el => {
      el.addEventListener('click', async () => {
        const handle = el.dataset.handle;
        const squadEl = el.closest('[data-squad-id]');
        const feedEl = squadEl.querySelector('.squad-feed');
        const feedBtn = squadEl.querySelector('.view-squad-feed-btn');
        if (!feedEl || !feedBtn) return;
        feedBtn.textContent = `Loading @${handle}...`;
        try {
          const res = await fetch(`${hubUrl}/api/bluesky-feed/author/${encodeURIComponent(handle)}?limit=10`, {
            headers: { Authorization: `Bearer ${token}` },
          });
          const data = await res.json();
          feedEl.innerHTML = (data.posts || []).map(post => renderSquadCard(post)).join('') || '<div class="text-center py-4 text-zinc-500">No posts</div>';
          feedEl.classList.remove('hidden');
          feedBtn.textContent = 'Hide Squad Feed';
        } catch {
          feedEl.innerHTML = '<div class="text-center py-4 text-red-400">Failed to load</div>';
          feedEl.classList.remove('hidden');
          feedBtn.textContent = 'Hide Squad Feed';
        }
      });
    });
  }

  function renderSquadCard(post) {
    const embed = post.embedData || {};
    let embedHtml = '';
    if (embed.images?.length > 1) {
      embedHtml += `<div class="grid grid-cols-2 gap-1 mt-2 rounded overflow-hidden">
        ${embed.images.map(img => `<img src="${escapeHtml(img.fullsize || img.thumb)}" alt="${escapeHtml(img.alt || '')}" class="w-full object-cover aspect-square" loading="lazy" onerror="this.style.display='none'" />`).join('')}
      </div>`;
    }
    if (embed.images?.length === 1) {
      embedHtml += `<div class="mt-2 bg-black flex justify-center rounded overflow-hidden"><img src="${escapeHtml(embed.images[0].fullsize || embed.images[0].thumb)}" alt="${escapeHtml(embed.images[0].alt || '')}" style="width:100%;max-height:20rem;object-fit:contain" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>`;
    }
    if (embed.video?.playlist) {
      embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video">
        <video controls preload="none" poster="${escapeHtml(embed.video.thumb || '')}" class="w-full h-full">
          <source src="${escapeHtml(embed.video.playlist)}" type="application/x-mpegURL" />
        </video>
      </div>`;
    }
    if (embed.external?.uri) {
      embedHtml += `<a href="${escapeHtml(embed.external.uri)}" target="_blank" rel="noopener noreferrer" class="mt-2 block rounded border border-zinc-700 overflow-hidden hover:border-zinc-500 transition">
        ${embed.external.thumb ? `<img src="${escapeHtml(embed.external.thumb)}" alt="" class="w-full aspect-[2/1] object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
        <div class="p-3"><div class="text-sm font-medium text-zinc-200 line-clamp-1">${escapeHtml(embed.external.title || '')}</div></div>
      </a>`;
    }
    if (embed.quote?.text) {
      embedHtml += `<div class="mt-2 rounded border border-zinc-700 p-3 bg-zinc-800/50">
        <div class="text-xs text-zinc-400 mb-1"><span class="font-medium text-zinc-300">${escapeHtml(embed.quote.author)}</span> <span class="text-zinc-500">@${escapeHtml(embed.quote.handle)}</span></div>
        <p class="text-sm text-zinc-300 line-clamp-3">${escapeHtml(embed.quote.text)}</p>
      </div>`;
    }
    return `
    <article class="rounded-lg border border-zinc-800 bg-zinc-900/50 p-4">
      <div class="flex items-center gap-2 mb-2">
        ${post.author.avatar ? `<img src="${escapeHtml(post.author.avatar)}" class="h-8 w-8 rounded-full" />` : ''}
        <div>
          <span class="text-sm font-medium">${escapeHtml(post.author.displayName)}</span>
          <span class="text-xs text-zinc-500 ml-1">@${escapeHtml(post.author.handle)}</span>
        </div>
        <time class="text-xs text-zinc-500 ml-auto">${timeAgo(post.pubDate)}</time>
      </div>
      ${post.text ? `<p class="text-sm whitespace-pre-wrap">${escapeHtml(post.text)}</p>` : ''}
      ${embedHtml}
      <div class="mt-2 flex items-center gap-3 text-xs text-zinc-500">
        <span>♡ ${post.likeCount}</span>
        <span>🔁 ${post.repostCount}</span>
        <span>💬 ${post.replyCount}</span>
        <a href="${escapeHtml(post.link)}" target="_blank" class="hover:text-white ml-auto">↗ Open</a>
      </div>
    </article>`;
  }

  function formatWindow(minutes) {
    if (minutes < 60) return `${minutes}m`;
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return m ? `${h}h ${m}m` : `${h}h`;
  }

  function timeAgo(dateStr) {
    if (!dateStr) return 'never';
    const seconds = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
    if (seconds < 60) return 'just now';
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes}m ago`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    return `${days}d ago`;
  }

  // Auto-load if signed in
  if (token) {
    loadFeed();
  }
</script>

<style>
  .active-tab {
    background-color: rgb(82 82 91); /* zinc-600 */
  }
  input[type="range"] {
    height: 4px;
    border-radius: 2px;
    background: #3f3f46;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
  }
  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #3b82f6;
    cursor: pointer;
  }
</style>
