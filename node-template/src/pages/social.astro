---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/config';
import labels from '../content/labels.json';
const sl = labels.social;
---

<BaseLayout title="Social">
  <div class="mx-auto max-w-3xl">
    <div class="sticky top-[41px] md:top-[57px] z-30 -mx-4 px-3 py-2 md:px-4 md:py-4 mb-4 md:mb-8 flex items-center justify-center bg-theme-bg/95 backdrop-blur supports-[backdrop-filter]:bg-theme-bg/80 border-b border-theme-border">
      <div class="flex gap-1 md:gap-2 flex-wrap justify-center">
        <button id="tab-timeline" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition active-tab">
          {sl.tabTimeline}
        </button>
        <select id="tab-feeds" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition cursor-pointer" style="appearance:none;-webkit-appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23999%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>');background-repeat:no-repeat;background-position:right 6px center;padding-right:20px">
          <option value="" disabled selected>Feeds</option>
        </select>
        <button id="tab-discover" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabDiscover}
        </button>
        <button id="tab-squads" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabSquads}
        </button>
        <button id="tab-posts" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          Posts
        </button>
        <button id="tab-youtube" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabYouTube}
        </button>
        <button id="tab-rss" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          RSS
        </button>
      </div>
    </div>

    <!-- Filter pills (shown for Feed tab) -->
    <div id="feed-filters" class="flex gap-1.5 flex-wrap mb-4">
      <button class="filter-pill active-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="all">All</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="no-reposts">No Reposts</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="images">Images</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="videos">Videos</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="youtube">YouTube</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="text">Text Only</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="links">Links</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="pirate">Pirate RSS</button>
    </div>

    <!-- Discover sub-tabs (shown for Discover tab) -->
    <div id="discover-pills" class="hidden flex gap-1.5 flex-wrap mb-4">
      <button class="discover-pill active-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-sub="trending">Trending</button>
      <button class="discover-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-sub="people">People</button>
      <button class="discover-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-sub="feeds">Custom Feeds</button>
    </div>

    <!-- Search bar (HIDDEN) -->
    <div id="search-bar" class="hidden mb-4"></div>

    <!-- RSS management section (shown for RSS tab) -->
    <div id="rss-management" class="hidden mb-4 space-y-4"></div>

    <!-- Post composer (shown when logged in to Bluesky) -->
    <div id="compose-box" style="display:none" class="mb-6 rounded-lg border border-theme-card-border bg-theme-card p-4">
      <textarea id="compose-input" rows="3" placeholder="What's on your mind?" style="width:100%;background:var(--ps-input-bg,#1a1a2e);border:1px solid var(--ps-input-border,#333);border-radius:.5rem;padding:.75rem;color:var(--ps-text,#e0e0e0);font-size:.875rem;resize:vertical;outline:none" maxlength="300"></textarea>
      <div id="compose-link-preview"></div>
      <div class="flex items-center justify-between mt-2">
        <span id="compose-count" class="text-xs text-theme-faint">0/300</span>
        <button id="compose-send" style="background:var(--ps-accent,#3b82f6);color:#fff;border:none;border-radius:.375rem;padding:.375rem 1rem;font-size:.875rem;cursor:pointer;opacity:.5" disabled>Post</button>
      </div>
    </div>

    <!-- Main content -->
    <div id="feed-container" class="space-y-6">
      <div class="text-center text-theme-faint py-12">
        <div class="loader-spinner mx-auto h-6 w-6 border-2 border-theme-border border-t-theme-muted rounded-full animate-spin"></div>
        <p class="mt-2">Loading...</p>
      </div>
    </div>

    <!-- Scroll sentinel -->
    <div id="scroll-sentinel" class="mt-8 flex justify-center py-4 hidden">
      <div class="loader-spinner h-6 w-6 border-2 border-theme-border border-t-theme-muted rounded-full animate-spin"></div>
    </div>
  </div>

  <!-- Thread/Profile slide-over panel -->
  <div id="slide-panel" class="fixed inset-0 z-50 hidden">
    <div id="slide-backdrop" class="absolute inset-0 bg-black/60"></div>
    <div id="slide-content" class="absolute right-0 top-0 h-full w-full max-w-lg bg-theme-bg border-l border-theme-border overflow-y-auto" style="transform:translateX(100%);transition:transform .3s ease">
      <div class="sticky top-0 bg-theme-bg/95 backdrop-blur border-b border-theme-border p-4 flex items-center justify-between z-10">
        <h2 id="slide-title" class="font-semibold text-sm"></h2>
        <button id="slide-close" class="text-theme-muted hover:text-theme-text text-xl">✕</button>
      </div>
      <div id="slide-body" class="p-4 space-y-4"></div>
    </div>
  </div>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/hls.js@latest/dist/hls.min.js"></script>
<script is:inline define:vars={{ hubUrl: siteConfig.hubUrl, L: labels.social, FL: labels.feeds }} data-astro-rerun>
  // ============================================================
  // STATE
  // ============================================================
  const token = localStorage.getItem('ps_token');
  const feedContainer = document.getElementById('feed-container');
  const scrollSentinel = document.getElementById('scroll-sentinel');
  const filterBar = document.getElementById('feed-filters');
  const discoverPills = document.getElementById('discover-pills');
  const rssManagement = document.getElementById('rss-management');

  let currentTab = 'timeline';
  let currentFilter = 'all';
  let currentDiscoverSub = 'trending';
  let currentSearchType = 'posts';
  let bskyCursor = null;
  let piratePage = 1;
  let isLoading = false;
  let hasMore = true;
  let bskySession = null;
  let myHandle = null;
  let myDid = null;
  let myAvatar = null;
  // Track own likes/reposts for optimistic UI
  let myLikes = {};    // uri -> likeUri
  let myReposts = {};  // uri -> repostUri

  // Squad member lookup for highlighting (handle -> color)
  let squadMemberHandles = new Map();

  // YouTube state
  let youtubeChannels = [];
  let youtubeWatchlist = [];
  let showYouTubeInFeed = true;

  // Squad state
  let allSquads = [];
  let squadsInitialized = false;

  // Social settings (persisted in localStorage)
  const defaultSocialSettings = { squadHighlight: true, squadBorderColor: '#eab308', miniPlayerEnabled: true, miniPlayerX: null, miniPlayerY: null };
  let socialSettings = { ...defaultSocialSettings };
  try { const s = JSON.parse(localStorage.getItem('ps_social_settings')); if (s) socialSettings = { ...defaultSocialSettings, ...s }; } catch {}
  function saveSocialSettings() { localStorage.setItem('ps_social_settings', JSON.stringify(socialSettings)); }

  // Subscribed custom feeds (persisted in localStorage)
  let subscribedFeeds = []; // [{uri, name, avatar}]
  try { const sf = JSON.parse(localStorage.getItem('ps_subscribed_feeds')); if (Array.isArray(sf)) subscribedFeeds = sf; } catch {}
  function saveSubscribedFeeds() { localStorage.setItem('ps_subscribed_feeds', JSON.stringify(subscribedFeeds)); }
  function isSubscribed(feedUri) { return subscribedFeeds.some(f => f.uri === feedUri); }
  function subscribeFeed(uri, name, avatar) {
    if (!isSubscribed(uri)) { subscribedFeeds.push({ uri, name, avatar }); saveSubscribedFeeds(); populateFeedsDropdown(); }
  }
  function unsubscribeFeed(uri) {
    subscribedFeeds = subscribedFeeds.filter(f => f.uri !== uri);
    saveSubscribedFeeds();
    populateFeedsDropdown();
  }

  // ============================================================
  // SVG ICONS (Feather-style stroke icons + Bluesky butterfly)
  // ============================================================
  const ICON = {
    heart: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`,
    heartFill: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`,
    repost: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 2 21 6 17 10"></polyline><path d="M3 11v-1a4 4 0 0 1 4-4h14"></path><polyline points="7 22 3 18 7 14"></polyline><path d="M21 13v1a4 4 0 0 1-4 4H3"></path></svg>`,
    reply: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>`,
    share: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>`,
    squad: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
    butterfly: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M1.159 1.829c.284-.16.625-.174.941-.127.466.071.905.259 1.317.482.698.381 1.305.903 1.871 1.457a20.933 20.933 0 0 1 2.233 2.65c.544.768 1.063 1.558 1.48 2.403.316-.645.698-1.254 1.096-1.851a23.74 23.74 0 0 1 1.238-1.672c.466-.573.958-1.125 1.49-1.639.477-.457.983-.889 1.551-1.229a5.09 5.09 0 0 1 1.089-.501c.339-.102.702-.166 1.054-.095.258.051.497.198.651.412.205.281.282.633.311.974.021.239.01.478-.005.717a80.443 80.443 0 0 1-.221 2.776 37.19 37.19 0 0 1-.126 1.152c-.039.27-.066.544-.156.803a3.131 3.131 0 0 1-.993 1.47c-.453.371-1.005.607-1.575.729-.692.15-1.412.144-2.11.035.732.131 1.464.332 2.114.703.429.247.827.584 1.05 1.033.187.369.223.804.122 1.203-.132.535-.454 1.003-.824 1.403a6.833 6.833 0 0 1-1.028.909c-.401.28-.853.51-1.343.573a1.883 1.883 0 0 1-1.127-.203c-.45-.234-.804-.615-1.092-1.026-.462-.666-.774-1.421-1.035-2.184-.04-.108-.07-.221-.12-.325l-.025.001c-.08.184-.133.379-.204.567-.244.682-.54 1.353-.956 1.95-.209.297-.45.574-.739.796a2.097 2.097 0 0 1-.797.39 1.97 1.97 0 0 1-.947-.017 3.313 3.313 0 0 1-1.02-.485c-.336-.23-.643-.5-.929-.788-.379-.379-.718-.816-.905-1.323a1.874 1.874 0 0 1-.085-1.068c.083-.361.29-.684.555-.939.464-.446 1.063-.719 1.67-.913a7.8 7.8 0 0 1 1.087-.256 6.658 6.658 0 0 1-1.367.067c-.802-.05-1.614-.281-2.258-.776a3.092 3.092 0 0 1-.967-1.263 2.8 2.8 0 0 1-.189-.627C.858 7.71.812 7.239.763 6.769a83.74 83.74 0 0 1-.238-2.961c-.03-.438-.031-.891.113-1.312.092-.272.265-.528.521-.67Z"/></svg>`,
    externalLink: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>`,
    squadBadge: `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
  };

  // ============================================================
  // BLUESKY SESSION MANAGEMENT
  // ============================================================
  function loadBskySession() {
    try {
      const stored = localStorage.getItem('ps_bsky_session');
      if (stored) bskySession = JSON.parse(stored);
    } catch { bskySession = null; }
    return bskySession;
  }

  function saveBskySession(s) {
    bskySession = s;
    localStorage.setItem('ps_bsky_session', JSON.stringify(s));
  }

  async function ensureBskySession() {
    if (bskySession?.accessJwt) return bskySession;
    loadBskySession();
    if (bskySession?.accessJwt) return bskySession;
    if (!token) return null;
    try {
      const res = await fetchTimeout(`${hubUrl}/api/bluesky/session`, { headers: { Authorization: `Bearer ${token}` } }, 10000);
      if (res.ok) { const d = await res.json(); saveBskySession(d); return d; }
      else {
        const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
        console.warn('[PS] Bluesky session error:', err.error);
      }
    } catch (err) {
      console.warn('[PS] Bluesky session error:', err.message);
    }
    return null;
  }

  async function refreshBskySession() {
    if (!bskySession?.refreshJwt) return null;
    try {
      const res = await fetchTimeout('https://bsky.social/xrpc/com.atproto.server.refreshSession', {
        method: 'POST', headers: { Authorization: `Bearer ${bskySession.refreshJwt}` },
      }, 8000);
      if (res.ok) {
        const d = await res.json();
        bskySession.accessJwt = d.accessJwt;
        if (d.refreshJwt) bskySession.refreshJwt = d.refreshJwt;
        saveBskySession(bskySession);
        return bskySession;
      }
      localStorage.removeItem('ps_bsky_session');
      bskySession = null;
      return ensureBskySession();
    } catch { return null; }
  }

  // ============================================================
  // DIRECT AT PROTOCOL CALLS
  // ============================================================
  const BSKY_PUBLIC = 'https://public.api.bsky.app/xrpc';
  const BSKY_AUTH = 'https://bsky.social/xrpc';

  function fetchTimeout(url, opts = {}, ms = 8000) {
    const c = new AbortController();
    const t = setTimeout(() => c.abort(), ms);
    return fetch(url, { ...opts, signal: c.signal }).finally(() => clearTimeout(t));
  }

  async function bskyGet(endpoint, params = {}, auth = false) {
    const base = auth ? BSKY_AUTH : BSKY_PUBLIC;
    const qs = new URLSearchParams(params).toString();
    const url = `${base}/${endpoint}${qs ? '?' + qs : ''}`;
    const headers = {};
    if (auth && bskySession?.accessJwt) headers.Authorization = `Bearer ${bskySession.accessJwt}`;
    const res = await fetchTimeout(url, { headers }, 10000);
    if ((res.status === 401 || res.status === 400) && auth) {
      const refreshed = await refreshBskySession();
      if (refreshed?.accessJwt) {
        headers.Authorization = `Bearer ${refreshed.accessJwt}`;
        const retry = await fetchTimeout(url, { headers }, 10000);
        if (!retry.ok) throw new Error(`API ${retry.status}`);
        return retry.json();
      }
      throw new Error('Auth expired');
    }
    if (!res.ok) throw new Error(`API ${res.status}`);
    return res.json();
  }

  async function bskyPost(endpoint, body) {
    const url = `${BSKY_AUTH}/${endpoint}`;
    const res = await fetchTimeout(url, {
      method: 'POST',
      headers: { Authorization: `Bearer ${bskySession.accessJwt}`, 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    }, 10000);
    if (res.status === 401) {
      const refreshed = await refreshBskySession();
      if (refreshed?.accessJwt) {
        const retry = await fetchTimeout(url, {
          method: 'POST',
          headers: { Authorization: `Bearer ${refreshed.accessJwt}`, 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        }, 10000);
        if (!retry.ok) throw new Error(`API ${retry.status}`);
        return retry.json();
      }
      throw new Error('Auth expired');
    }
    if (!res.ok) throw new Error(`API ${res.status}`);
    return res.json();
  }

  // --- Feed fetchers ---
  async function fetchBskyTimeline(cursor) {
    const params = { limit: '25' };
    if (cursor) params.cursor = cursor;
    return bskyGet('app.bsky.feed.getTimeline', params, true);
  }

  async function fetchBskyDiscover(cursor) {
    // Popular/discover feed
    const params = { limit: '25', feed: 'at://did:plc:z72i7hdynmk6r22z27h6tvur/app.bsky.feed.generator/whats-hot' };
    if (cursor) params.cursor = cursor;
    return bskyGet('app.bsky.feed.getFeed', params, true);
  }

  async function fetchBskyAuthorFeed(handle, cursor) {
    const params = { actor: handle, limit: '15', filter: 'posts_and_author_threads' };
    if (cursor) params.cursor = cursor;
    return bskyGet('app.bsky.feed.getAuthorFeed', params);
  }

  async function fetchBskyThread(uri) {
    return bskyGet('app.bsky.feed.getPostThread', { uri, depth: '10' });
  }

  async function fetchBskyProfile(handle) {
    return bskyGet('app.bsky.actor.getProfile', { actor: handle });
  }

  async function searchBskyPosts(query, cursor) {
    const params = { q: query, limit: '25' };
    if (cursor) params.cursor = cursor;
    return bskyGet('app.bsky.feed.searchPosts', params, true);
  }

  async function searchBskyActors(query, cursor) {
    const params = { q: query, limit: '25' };
    if (cursor) params.cursor = cursor;
    return bskyGet('app.bsky.actor.searchActors', params, true);
  }

  async function searchBskyFeeds(query, cursor) {
    const params = { limit: '25' };
    if (cursor) params.cursor = cursor;
    if (query) params.q = query;
    return bskyGet('app.bsky.feed.getSuggestedFeeds', params, true);
  }

  async function fetchCustomFeed(feedUri, cursor) {
    const params = { feed: feedUri, limit: '25' };
    if (cursor) params.cursor = cursor;
    return bskyGet('app.bsky.feed.getFeed', params, true);
  }

  async function fetchTrendingTopics() {
    try {
      return await bskyGet('app.bsky.unspecced.getTrendingTopics', {});
    } catch { return { topics: [], suggested: [] }; }
  }

  // --- Interactions ---
  async function likeBskyPost(uri, cid) {
    const res = await bskyPost('com.atproto.repo.createRecord', {
      repo: bskySession.did, collection: 'app.bsky.feed.like',
      record: { subject: { uri, cid }, createdAt: new Date().toISOString(), '$type': 'app.bsky.feed.like' },
    });
    myLikes[uri] = res.uri;
    return res.uri;
  }

  async function unlikeBskyPost(uri) {
    const likeUri = myLikes[uri];
    if (!likeUri) return;
    const rkey = likeUri.split('/').pop();
    await bskyPost('com.atproto.repo.deleteRecord', {
      repo: bskySession.did, collection: 'app.bsky.feed.like', rkey,
    });
    delete myLikes[uri];
  }

  async function repostBskyPost(uri, cid) {
    const res = await bskyPost('com.atproto.repo.createRecord', {
      repo: bskySession.did, collection: 'app.bsky.feed.repost',
      record: { subject: { uri, cid }, createdAt: new Date().toISOString(), '$type': 'app.bsky.feed.repost' },
    });
    myReposts[uri] = res.uri;
    return res.uri;
  }

  async function unrepostBskyPost(uri) {
    const repostUri = myReposts[uri];
    if (!repostUri) return;
    const rkey = repostUri.split('/').pop();
    await bskyPost('com.atproto.repo.deleteRecord', {
      repo: bskySession.did, collection: 'app.bsky.feed.repost', rkey,
    });
    delete myReposts[uri];
  }

  // Create a new Bluesky post or reply
  // linkCard can be passed from the preview UI to avoid re-fetching
  async function createBskyRecord(text, replyTo, linkCard) {
    // If a link card is attached, strip the detected URL from the body text to save space
    if (linkCard && !linkCard.removed && linkCard.url) {
      const cardUrl = linkCard.url.replace(/^https?:\/\//, '');
      // Try stripping the full URL first, then bare domain form
      text = text.replace(new RegExp(`https?:\\/\\/${cardUrl.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\$&')}`, 'g'), '').trim();
      text = text.replace(new RegExp(`(?:^|\\s)${cardUrl.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\$&')}(?=\\s|$)`, 'g'), '').trim();
      // Clean up double spaces left behind
      text = text.replace(/  +/g, ' ').trim();
    }
    const record = {
      '$type': 'app.bsky.feed.post',
      text,
      createdAt: new Date().toISOString(),
    };
    // Parse facets (links, mentions)
    const facets = [];
    const urls = [];
    // Detect full URLs
    const urlRegex = /https?:\/\/[^\s)>\]]+/g;
    let m;
    while ((m = urlRegex.exec(text)) !== null) {
      urls.push(m[0]);
      facets.push({
        index: { byteStart: new TextEncoder().encode(text.slice(0, m.index)).length, byteEnd: new TextEncoder().encode(text.slice(0, m.index + m[0].length)).length },
        features: [{ '$type': 'app.bsky.richtext.facet#link', uri: m[0] }],
      });
    }
    // Detect bare domains (e.g. toddlambert.com, news.ycombinator.com)
    const bareDomainRegex = /(?<=^|\s)((?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,}(?:\/[^\s)>\]]*)?)(?=\s|$)/g;
    while ((m = bareDomainRegex.exec(text)) !== null) {
      const fullUrl = `https://${m[1]}`;
      // Skip if this position was already matched as a full URL
      if (urls.some(u => text.indexOf(u) <= m.index && text.indexOf(u) + u.length >= m.index + m[0].length)) continue;
      urls.push(fullUrl);
      facets.push({
        index: { byteStart: new TextEncoder().encode(text.slice(0, m.index)).length, byteEnd: new TextEncoder().encode(text.slice(0, m.index + m[0].length)).length },
        features: [{ '$type': 'app.bsky.richtext.facet#link', uri: fullUrl }],
      });
    }
    // Detect mentions
    const mentionRegex = /(?<=^|\s)@([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?/g;
    while ((m = mentionRegex.exec(text)) !== null) {
      const handle = m[0].slice(1);
      try {
        const resolved = await bskyGet('com.atproto.identity.resolveHandle', { handle }, false);
        if (resolved?.did) {
          facets.push({
            index: { byteStart: new TextEncoder().encode(text.slice(0, m.index)).length, byteEnd: new TextEncoder().encode(text.slice(0, m.index + m[0].length)).length },
            features: [{ '$type': 'app.bsky.richtext.facet#mention', did: resolved.did }],
          });
        }
      } catch {}
    }
    if (facets.length) record.facets = facets;

    // Attach link card embed — use pre-fetched card if provided
    if (linkCard && !linkCard.removed) {
      const external = {
        '$type': 'app.bsky.embed.external',
        external: { uri: linkCard.url, title: linkCard.title || '', description: linkCard.description || '' },
      };
      if (linkCard.thumb) external.external.thumb = linkCard.thumb;
      record.embed = external;
    }

    if (replyTo) {
      record.reply = {
        root: replyTo.root || { uri: replyTo.uri, cid: replyTo.cid },
        parent: { uri: replyTo.uri, cid: replyTo.cid },
      };
    }
    return bskyPost('com.atproto.repo.createRecord', {
      repo: bskySession.did, collection: 'app.bsky.feed.post', record,
    });
  }

  // ============================================================
  // LINK PREVIEW SYSTEM
  // ============================================================
  function extractFirstUrl(text) {
    const full = text.match(/https?:\/\/[^\s)>\]]+/);
    if (full) return full[0];
    const bare = text.match(/(?:^|\s)((?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,}(?:\/[^\s)>\]]*)?)/);
    if (bare) return `https://${bare[1]}`;
    return null;
  }

  function renderLinkPreview(container, card) {
    if (!card || card.removed) { container.innerHTML = ''; return; }
    const imgHtml = `
      <div data-lp-img-area style="position:relative;cursor:pointer;min-height:3rem;background:var(--ps-input-bg,#1a1a2e)">
        ${card.image ? `<img data-lp-img src="${escapeHtml(card.image)}" style="width:100%;max-height:14rem;object-fit:contain;display:block;background:var(--ps-input-bg,#1a1a2e)" onload="if(this.naturalHeight>this.naturalWidth){this.style.objectFit='cover';this.style.maxHeight='10rem'}" onerror="this.style.display='none'" />` : ''}
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.35);opacity:0;transition:opacity .15s" data-lp-img-overlay>
          <span style="color:#fff;font-size:.75rem;background:rgba(0,0,0,.6);padding:.25rem .625rem;border-radius:.25rem">${card.image ? 'Replace image' : 'Add image'}</span>
        </div>
        <input data-lp-file type="file" accept="image/*" style="display:none" />
      </div>`;
    container.innerHTML = `
      <div style="margin-top:.75rem;border:1px solid var(--ps-card-border,#333);border-radius:.5rem;overflow:hidden;position:relative">
        <button data-lp-remove style="position:absolute;top:.5rem;right:.5rem;background:rgba(0,0,0,.6);color:#fff;border:none;border-radius:50%;width:1.5rem;height:1.5rem;font-size:.75rem;cursor:pointer;z-index:2;display:flex;align-items:center;justify-content:center">\u2715</button>
        ${imgHtml}
        <div style="padding:.75rem">
          <input data-lp-title type="text" value="${escapeHtml(card.title || '')}" placeholder="Title" style="width:100%;background:transparent;border:none;color:var(--ps-text,#e0e0e0);font-size:.875rem;font-weight:600;outline:none;margin-bottom:.25rem" />
          <textarea data-lp-desc rows="2" placeholder="Description" style="width:100%;background:transparent;border:none;color:var(--ps-text-muted,#aaa);font-size:.8rem;outline:none;resize:none">${escapeHtml(card.description || '')}</textarea>
          <div style="font-size:.7rem;color:var(--ps-text-faint,#666);margin-top:.25rem">${escapeHtml((() => { try { return new URL(card.url).hostname; } catch { return card.url; } })())}</div>
        </div>
      </div>`;
    // Wire editable fields back to the card object
    container.querySelector('[data-lp-title]').addEventListener('input', (e) => { card.title = e.target.value; });
    container.querySelector('[data-lp-desc]').addEventListener('input', (e) => { card.description = e.target.value; });
    container.querySelector('[data-lp-remove]').addEventListener('click', () => { card.removed = true; container.innerHTML = ''; });
    // Image hover overlay
    const imgArea = container.querySelector('[data-lp-img-area]');
    const overlay = container.querySelector('[data-lp-img-overlay]');
    const fileInput = container.querySelector('[data-lp-file]');
    imgArea.addEventListener('mouseenter', () => { overlay.style.opacity = '1'; });
    imgArea.addEventListener('mouseleave', () => { overlay.style.opacity = '0'; });
    imgArea.addEventListener('click', (e) => { if (e.target.closest('[data-lp-remove]')) return; fileInput.click(); });
    fileInput.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      if (!file || !file.type.startsWith('image/')) return;
      if (file.size > 1000000) { alert('Image must be under 1 MB'); return; }
      // Show local preview immediately
      const localUrl = URL.createObjectURL(file);
      let img = imgArea.querySelector('[data-lp-img]');
      if (!img) { img = document.createElement('img'); img.dataset.lpImg = ''; img.style.cssText = 'width:100%;max-height:14rem;object-fit:contain;display:block;background:var(--ps-input-bg,#1a1a2e)'; imgArea.prepend(img); }
      img.onload = function(){ if(this.naturalHeight>this.naturalWidth){this.style.objectFit='cover';this.style.maxHeight='10rem'} else {this.style.objectFit='contain';this.style.maxHeight='14rem'} };
      img.src = localUrl;
      card.image = localUrl;
      overlay.querySelector('span').textContent = 'Uploading...';
      overlay.style.opacity = '1';
      try {
        // Upload directly to Bluesky using existing session
        const uploadRes = await fetch('https://bsky.social/xrpc/com.atproto.repo.uploadBlob', {
          method: 'POST', headers: { Authorization: `Bearer ${bskySession.accessJwt}`, 'Content-Type': file.type },
          body: file,
        });
        const uploadData = await uploadRes.json();
        if (uploadData.blob) { card.thumb = uploadData.blob; }
        overlay.querySelector('span').textContent = 'Replace image';
        overlay.style.opacity = '0';
      } catch {
        overlay.querySelector('span').textContent = 'Upload failed — tap to retry';
        overlay.style.opacity = '1';
      }
    });
  }

  function setupLinkPreview(inputEl, previewContainer) {
    let currentCard = null;
    let lastCheckedUrl = null;
    let fetchTimer = null;
    let strippedUrl = false;

    inputEl.addEventListener('input', () => {
      if (strippedUrl) { strippedUrl = false; return; }
      const url = extractFirstUrl(inputEl.value);
      if (!url || url === lastCheckedUrl) {
        if (!url && currentCard && !currentCard.removed) { /* keep card visible — URL was stripped */ return; }
        if (!url && !currentCard) return;
        return;
      }
      clearTimeout(fetchTimer);
      fetchTimer = setTimeout(async () => {
        lastCheckedUrl = url;
        previewContainer.innerHTML = '<div style="padding:.5rem;text-align:center;font-size:.75rem;color:var(--ps-text-faint,#888)">Loading link preview...</div>';
        try {
          const res = await fetch(`${hubUrl}/api/bluesky/og-meta?url=${encodeURIComponent(url)}`, { headers: { Authorization: `Bearer ${token}` } });
          const og = await res.json();
          currentCard = { url, title: og.title || '', description: og.description || '', image: og.image || '', thumb: null, removed: false };
          // Upload thumbnail in background
          if (og.image) {
            fetch(`${hubUrl}/api/bluesky/upload-blob`, {
              method: 'POST', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
              body: JSON.stringify({ imageUrl: og.image }),
            }).then(r => r.json()).then(d => { if (d.blob && currentCard) currentCard.thumb = d.blob; }).catch(() => {});
          }
          renderLinkPreview(previewContainer, currentCard);
          // Strip the detected URL from the textarea to save character space
          const urlNoProt = url.replace(/^https?:\/\//, '');
          let val = inputEl.value;
          // Try full URL first, then bare domain
          val = val.replace(new RegExp(`https?:\\/\\/${urlNoProt.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\$&')}`, 'g'), '');
          val = val.replace(new RegExp(`(^|\\s)${urlNoProt.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\$&')}(?=\\s|$)`, 'g'), '$1');
          inputEl.value = val.replace(/  +/g, ' ').trim();
          strippedUrl = true;
          inputEl.dispatchEvent(new Event('input', { bubbles: true }));
        } catch {
          previewContainer.innerHTML = '';
          currentCard = null;
        }
      }, 600);
    });

    return () => currentCard; // getter for the current card
  }

  // ============================================================
  // NORMALIZE POST DATA
  // ============================================================
  function normalizeBskyPost(item) {
    const post = item.post;
    const reason = item.reason;
    const embed = post.embed;
    let embedData = {};
    let imageUrl = null;

    if (embed?.$type === 'app.bsky.embed.images#view') {
      embedData.images = embed.images.map(i => ({ thumb: i.thumb, fullsize: i.fullsize, alt: i.alt || '' }));
      if (embed.images[0]) imageUrl = embed.images[0].fullsize || embed.images[0].thumb;
    }
    if (embed?.$type === 'app.bsky.embed.video#view') {
      embedData.video = { playlist: embed.playlist, thumb: embed.thumbnail, alt: embed.alt || '' };
    }
    if (embed?.$type === 'app.bsky.embed.external#view') {
      embedData.external = { uri: embed.external.uri, title: embed.external.title, description: embed.external.description, thumb: embed.external.thumb };
    }
    if (embed?.$type === 'app.bsky.embed.recordWithMedia#view') {
      const media = embed.media;
      if (media?.$type === 'app.bsky.embed.images#view') {
        embedData.images = media.images.map(i => ({ thumb: i.thumb, fullsize: i.fullsize, alt: i.alt || '' }));
        if (media.images[0]) imageUrl = media.images[0].fullsize || media.images[0].thumb;
      }
      if (media?.$type === 'app.bsky.embed.video#view') {
        embedData.video = { playlist: media.playlist, thumb: media.thumbnail, alt: media.alt || '' };
      }
      if (media?.$type === 'app.bsky.embed.external#view') {
        embedData.external = { uri: media.external.uri, title: media.external.title, description: media.external.description, thumb: media.external.thumb };
      }
      const rec = embed.record?.record;
      if (rec?.value?.text) {
        embedData.quote = { text: rec.value.text, author: rec.author?.displayName || rec.author?.handle || '', handle: rec.author?.handle || '', avatar: rec.author?.avatar || '' };
      }
    }
    if (embed?.$type === 'app.bsky.embed.record#view') {
      const rec = embed.record;
      if (rec?.value?.text) {
        embedData.quote = { text: rec.value.text, author: rec.author?.displayName || rec.author?.handle || '', handle: rec.author?.handle || '', avatar: rec.author?.avatar || '' };
      }
    }

    // Track viewer state for likes/reposts
    const viewer = post.viewer || {};
    if (viewer.like) myLikes[post.uri] = viewer.like;
    if (viewer.repost) myReposts[post.uri] = viewer.repost;

    return {
      type: 'bluesky',
      uri: post.uri, cid: post.cid,
      author: { handle: post.author.handle, displayName: post.author.displayName || post.author.handle, avatar: post.author.avatar || '', did: post.author.did },
      text: post.record?.text || '',
      pubDate: post.indexedAt,
      imageUrl,
      embedData: Object.keys(embedData).length ? embedData : null,
      likeCount: post.likeCount || 0,
      repostCount: post.repostCount || 0,
      replyCount: post.replyCount || 0,
      liked: !!viewer.like,
      reposted: !!viewer.repost,
      repostBy: reason?.$type === 'app.bsky.feed.defs#reasonRepost'
        ? { handle: reason.by.handle, displayName: reason.by.displayName || reason.by.handle }
        : null,
      link: `https://bsky.app/profile/${post.author.handle}/post/${post.uri.split('/').pop()}`,
    };
  }

  function normalizePiratePost(post) {
    const isExternal = post.source === 'external';
    return {
      type: isExternal ? 'rss' : 'pirate',
      id: post.id,
      author: isExternal
        ? { handle: post.feed?.title || post.author || 'RSS', displayName: post.feed?.title || post.author || 'External', avatar: post.feed?.iconUrl || '', isRss: true }
        : { handle: post.user?.username || '', displayName: post.user?.displayName || post.user?.username || 'Unknown', avatar: post.user?.avatarUrl || '' },
      text: post.description || '',
      title: post.title || '',
      pubDate: post.pubDate,
      imageUrl: post.imageUrl,
      embedData: post.embedData || null,
      exifData: post.exifData || null,
      link: post.link || '',
      likeCount: post.likeCount || post._count?.likes || 0,
      commentCount: post.commentCount || post._count?.comments || 0,
      hasLiked: post.hasLiked || false,
    };
  }

  // ============================================================
  // FILTER LOGIC
  // ============================================================
  function matchesFilter(post, filter) {
    if (filter === 'all') return true;
    if (filter === 'pirate') return post.type === 'pirate' || post.type === 'rss';
    if (filter === 'no-reposts') return !post.repostBy;
    const embed = post.embedData || {};
    if (filter === 'images') return !!embed.images?.length || !!post.imageUrl;
    if (filter === 'videos') return !!embed.video?.playlist;
    if (filter === 'youtube') {
      const ytUri = embed.external?.uri;
      return ytUri && getYouTubeId(ytUri);
    }
    if (filter === 'text') return !embed.images && !embed.video && !embed.external && !post.imageUrl;
    if (filter === 'links') return !!embed.external?.uri;
    return true;
  }

  // ============================================================
  // RENDERING — UNIFIED POST CARD
  // ============================================================
  function escapeHtml(str) {
    if (!str) return '';
    const d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function formatText(str) {
    if (!str) return '';
    let text = str.replace(/&#xA;/gi, '\n').replace(/\[contains quote post or other embedded content\]/gi, '').trim();
    return escapeHtml(text).replace(/\n/g, '<br>');
  }

  function timeAgo(dateStr) {
    if (!dateStr) return '';
    const s = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
    if (s < 60) return 'just now';
    const m = Math.floor(s / 60);
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    const d = Math.floor(h / 24);
    if (d < 30) return `${d}d ago`;
    return new Date(dateStr).toLocaleDateString();
  }

  function getYouTubeId(url) {
    if (!url) return null;
    const m = url.match(/(?:(?:www\.|m\.|music\.)?youtube\.com\/(?:watch\?.*v=|embed\/|shorts\/|live\/|v\/)|youtu\.be\/)([\w-]{11})/);
    return m ? m[1] : null;
  }

  function formatExif(exif) {
    const parts = [];
    if (exif.camera) parts.push(exif.camera);
    if (exif.lens) parts.push(exif.lens);
    if (exif.focalLength) parts.push(exif.focalLength);
    if (exif.aperture) parts.push(`f/${exif.aperture}`);
    if (exif.shutterSpeed) parts.push(`${exif.shutterSpeed}s`);
    if (exif.iso) parts.push(`ISO ${exif.iso}`);
    return parts.join(' · ');
  }

  function renderEmbeds(embed) {
    if (!embed) return '';
    let html = '';

    // Multiple images (gallery)
    if (embed.images?.length > 1) {
      html += `<div class="grid grid-cols-2 gap-1 mt-2 rounded overflow-hidden">
        ${embed.images.map((img, i) => `<img src="${escapeHtml(img.fullsize || img.thumb)}" alt="${escapeHtml(img.alt || '')}" class="post-img w-full object-cover aspect-square" data-full="${escapeHtml(img.fullsize || img.thumb)}" data-alt="${escapeHtml(img.alt || '')}" data-img-group="${embed._groupId || ''}" data-img-idx="${i}" loading="lazy" onerror="this.style.display='none'" />`).join('')}
      </div>`;
    }
    // Single image
    if (embed.images?.length === 1) {
      html += `<div class="mt-2 bg-black flex justify-center rounded overflow-hidden"><img src="${escapeHtml(embed.images[0].fullsize || embed.images[0].thumb)}" alt="${escapeHtml(embed.images[0].alt || '')}" class="post-img" style="width:100%;max-height:28rem;object-fit:contain" data-full="${escapeHtml(embed.images[0].fullsize || embed.images[0].thumb)}" data-alt="${escapeHtml(embed.images[0].alt || '')}" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>`;
    }
    // Video (HLS)
    if (embed.video?.playlist) {
      html += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video">
        <video controls preload="none" poster="${escapeHtml(embed.video.thumb || '')}" class="w-full h-full" data-hls="${escapeHtml(embed.video.playlist)}"></video>
      </div>`;
    }
    // External link / YouTube
    if (embed.external?.uri) {
      const ytId = getYouTubeId(embed.external.uri);
      if (ytId) {
        html += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video yt-placeholder" data-yt-id="${ytId}" style="cursor:pointer;position:relative">
          <img src="https://i.ytimg.com/vi/${ytId}/hqdefault.jpg" class="w-full h-full object-cover" alt="" loading="lazy" onerror="this.style.display='none'" />
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
            <svg width="68" height="48" viewBox="0 0 68 48"><path d="M66.5 7.7s-.7-4.7-2.8-6.8C60.7-2 57.2-2 55.6-2.2 46.5-3 34-3 34-3s-12.5 0-21.6.8C10.8-2 7.3-2 4.3.9 2.2 3 1.5 7.7 1.5 7.7S.8 13.2.8 18.7v5.1c0 5.5.7 11 .7 11s.7 4.7 2.8 6.8c3 2.9 6.9 2.8 8.6 3.1 6.3.6 26.1.8 26.1.8s12.5 0 21.6-.8c1.6-.2 5.1-.2 8.1-3.1 2.1-2.1 2.8-6.8 2.8-6.8s.7-5.5.7-11v-5.1c0-5.5-.7-11-.7-11z" fill="red"/><path d="M27 33V13l18 10z" fill="#fff"/></svg>
          </div>
        </div>`;
      } else {
        html += `<a href="${escapeHtml(embed.external.uri)}" target="_blank" rel="noopener noreferrer" class="mt-2 block rounded border border-theme-input-border overflow-hidden hover:border-theme-card-hover transition">
          ${embed.external.thumb ? `<img src="${escapeHtml(embed.external.thumb)}" alt="" class="w-full aspect-[2/1] object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
          <div class="p-3">
            <div class="text-sm font-medium text-theme-text line-clamp-1">${escapeHtml(embed.external.title || '')}</div>
            ${embed.external.description ? `<div class="text-xs text-theme-faint mt-1 line-clamp-2">${escapeHtml(embed.external.description)}</div>` : ''}
            <div class="text-xs text-theme-faint mt-1">${escapeHtml((() => { try { return new URL(embed.external.uri).hostname; } catch { return ''; } })())}</div>
          </div>
        </a>`;
      }
    }
    // Quote
    if (embed.quote?.text) {
      html += `<div class="mt-2 rounded border border-theme-input-border p-3 bg-theme-surface/50">
        <div class="flex items-center gap-1.5 text-xs text-theme-muted mb-1">
          ${embed.quote.avatar ? `<img src="${escapeHtml(embed.quote.avatar)}" class="h-4 w-4 rounded-full" />` : ''}
          <span class="font-medium text-theme-text">${escapeHtml(embed.quote.author)}</span>
          <span class="text-theme-faint">@${escapeHtml(embed.quote.handle)}</span>
        </div>
        <p class="text-sm text-theme-text line-clamp-4">${escapeHtml(embed.quote.text)}</p>
      </div>`;
    }
    return html;
  }

  function renderPostCard(post) {
    const embed = post.embedData || {};
    const embedHtml = renderEmbeds(post.embedData);

    // Primary image (non-embed)
    const showPrimaryImage = !embed.images?.length && post.imageUrl;

    if (post.type === 'bluesky') {
      const liked = !!myLikes[post.uri];
      const reposted = !!myReposts[post.uri];
      const repostLine = post.repostBy
        ? `<div class="flex items-center gap-1 text-xs text-theme-faint mb-2">${ICON.repost} Reposted by ${escapeHtml(post.repostBy.displayName)}</div>`
        : '';

      const squadColor = squadMemberHandles.get(post.author.handle);
      const isSquadMember = !!squadColor;
      const squadBorder = isSquadMember && socialSettings.squadHighlight ? `border-color:${squadColor}` : '';
      const squadBadgeHtml = isSquadMember && socialSettings.squadHighlight ? `<span style="color:${squadColor};display:inline-flex;vertical-align:middle;margin-left:4px" title="Squad member">${ICON.squadBadge}</span>` : '';

      return `
        <article class="rounded-lg border border-theme-card-border bg-theme-card overflow-hidden" data-uri="${escapeHtml(post.uri)}" data-cid="${escapeHtml(post.cid)}" style="${squadBorder}">
          <div class="p-4">
            ${repostLine}
            <div class="flex items-center gap-3 mb-3">
              ${post.author.avatar ? `<img src="${escapeHtml(post.author.avatar)}" class="h-10 w-10 rounded-full cursor-pointer bsky-avatar" data-handle="${escapeHtml(post.author.handle)}" />` : '<div class="h-10 w-10 rounded-full bg-theme-surface-hover"></div>'}
              <div class="min-w-0 flex-1">
                <button class="bsky-avatar font-medium text-sm hover:underline text-left" data-handle="${escapeHtml(post.author.handle)}">${escapeHtml(post.author.displayName)}${squadBadgeHtml}</button>
                <div class="text-xs text-theme-faint">@${escapeHtml(post.author.handle)}</div>
              </div>
              <time class="text-xs text-theme-faint shrink-0">${timeAgo(post.pubDate)}</time>
            </div>
            ${post.text ? `<p class="text-sm whitespace-pre-wrap mb-2">${formatText(post.text)}</p>` : ''}
            ${showPrimaryImage ? `<div class="mt-2 bg-black flex justify-center rounded overflow-hidden"><img src="${escapeHtml(post.imageUrl)}" class="post-img" style="width:100%;max-height:28rem;object-fit:contain" data-full="${escapeHtml(post.imageUrl)}" data-alt="" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>` : ''}
            ${embedHtml}
            <div class="mt-3 flex items-center gap-1 text-xs text-theme-faint">
              <button class="bsky-like-btn flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover transition ${liked ? 'text-red-400' : ''}" data-uri="${escapeHtml(post.uri)}" data-cid="${escapeHtml(post.cid)}">
                ${liked ? ICON.heartFill : ICON.heart} <span class="like-count">${post.likeCount}</span>
              </button>
              <button class="bsky-repost-btn flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover transition ${reposted ? 'text-green-400' : ''}" data-uri="${escapeHtml(post.uri)}" data-cid="${escapeHtml(post.cid)}">
                ${ICON.repost} <span class="repost-count">${post.repostCount}</span>
              </button>
              <button class="bsky-reply-btn flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover transition" data-uri="${escapeHtml(post.uri)}">
                ${ICON.reply} ${post.replyCount}
              </button>
              <button class="bsky-squad-btn flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover transition" data-handle="${escapeHtml(post.author.handle)}" title="Add to Squad">
                ${ICON.squad}
              </button>
              <div class="ml-auto flex items-center gap-1">
                <button class="share-btn px-2 py-1 rounded hover:bg-theme-surface-hover transition" data-url="${escapeHtml(post.link)}" data-title="${escapeHtml(post.text?.slice(0, 100) || '')}" title="Share">${ICON.share}</button>
                <a href="${escapeHtml(post.link)}" target="_blank" rel="noopener noreferrer" class="px-2 py-1 rounded hover:bg-theme-surface-hover hover:text-theme-text transition" title="View on Bluesky">${ICON.butterfly}</a>
              </div>
            </div>
          </div>
        </article>`;
    }

    // Pirate Social / RSS post
    const isRss = post.type === 'rss';
    const authorHtml = isRss
      ? `<div class="flex items-center gap-2">
          ${post.author.avatar ? `<img src="${escapeHtml(post.author.avatar)}" class="h-8 w-8 rounded" onerror="this.style.display='none'" />` : '<div class="h-8 w-8 rounded bg-theme-surface-hover flex items-center justify-center text-theme-muted text-xs">RSS</div>'}
          <div>
            <span class="font-medium text-sm">${escapeHtml(post.author.displayName)}</span>
            <span class="ml-2 text-xs px-1.5 py-0.5 rounded bg-theme-input-bg text-theme-muted">RSS</span>
            <time class="block text-xs text-theme-faint">${timeAgo(post.pubDate)}</time>
          </div>
        </div>`
      : `<div class="flex items-center gap-3">
          ${post.author.avatar ? `<img src="${escapeHtml(post.author.avatar)}" class="h-8 w-8 rounded-full" />` : ''}
          <div>
            <a href="${hubUrl}/../${escapeHtml(post.author.handle)}" class="font-medium text-sm hover:underline">${escapeHtml(post.author.displayName)}</a>
            <time class="block text-xs text-theme-faint">${timeAgo(post.pubDate)}</time>
          </div>
        </div>`;

    const actionsHtml = isRss
      ? `<a href="${escapeHtml(post.link)}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 hover:text-theme-text transition">${ICON.externalLink} Read</a>
         <button class="share-btn flex items-center gap-1 hover:text-green-500 transition" data-url="${escapeHtml(post.link)}" data-title="${escapeHtml(post.title || '')}">${ICON.share} Share</button>`
      : `<button class="like-btn flex items-center gap-1 hover:text-red-400 transition ${post.hasLiked ? 'text-red-400' : ''}" data-post-id="${post.id}">
            ${post.hasLiked ? ICON.heartFill : ICON.heart} ${post.likeCount}
          </button>
          <button class="comment-btn flex items-center gap-1 hover:text-theme-primary transition" data-post-id="${post.id}">
            ${ICON.reply} ${post.commentCount}
          </button>
          <button class="share-btn flex items-center gap-1 hover:text-green-500 transition" data-url="${escapeHtml(post.link)}" data-title="${escapeHtml(post.title || '')}">${ICON.share} Share</button>
          ${post.link ? `<a href="${escapeHtml(post.link)}" target="_blank" class="flex items-center gap-1 hover:text-theme-text ml-auto">${ICON.externalLink} View</a>` : ''}`;

    return `
      <article class="rounded-lg border border-theme-card-border bg-theme-card overflow-hidden">
        ${showPrimaryImage ? `<div class="bg-black flex justify-center"><img src="${escapeHtml(post.imageUrl)}" alt="${escapeHtml(post.title)}" class="post-img" style="width:100%;max-height:28rem;object-fit:contain" data-full="${escapeHtml(post.imageUrl)}" data-alt="${escapeHtml(post.title || '')}" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>` : ''}
        <div class="p-4">
          <div class="mb-3">${authorHtml}</div>
          ${post.title && !embed.external?.uri ? `<h3 class="font-semibold"><a href="${escapeHtml(post.link)}" target="_blank" class="hover:underline">${formatText(post.title)}</a></h3>` : ''}
          ${post.text && post.text !== post.title && !embed.external?.uri ? `<p class="mt-1 text-sm text-theme-muted">${formatText(post.text)}</p>` : ''}
          ${embedHtml}
          ${post.exifData ? `<div class="mt-2 text-xs text-theme-faint">${formatExif(post.exifData)}</div>` : ''}
          <div class="mt-3 flex items-center gap-4 text-sm text-theme-muted">${actionsHtml}</div>
        </div>
      </article>`;
  }

  // ============================================================
  // RENDERING — PEOPLE / PROFILES
  // ============================================================
  function renderBskyUserCard(actor) {
    return `
      <div class="flex items-center gap-4 rounded-lg border border-theme-card-border bg-theme-card p-4">
        ${actor.avatar ? `<img src="${escapeHtml(actor.avatar)}" class="h-12 w-12 rounded-full cursor-pointer bsky-avatar" data-handle="${escapeHtml(actor.handle)}" />` : '<div class="h-12 w-12 rounded-full bg-theme-surface-hover"></div>'}
        <div class="flex-1 min-w-0">
          <button class="bsky-avatar font-medium hover:underline text-left" data-handle="${escapeHtml(actor.handle)}">${escapeHtml(actor.displayName || actor.handle)}</button>
          <p class="text-sm text-theme-muted">@${escapeHtml(actor.handle)}</p>
          ${actor.description ? `<p class="text-sm text-theme-faint mt-1 line-clamp-2">${escapeHtml(actor.description)}</p>` : ''}
        </div>
        <div class="text-right text-xs text-theme-faint shrink-0">
          <div>${actor.followersCount ?? 0} followers</div>
          <div>${actor.postsCount ?? 0} posts</div>
        </div>
      </div>`;
  }

  function renderPirateUserCard(user) {
    return `
      <div class="flex items-center gap-4 rounded-lg border border-theme-card-border bg-theme-card p-4">
        ${user.avatarUrl ? `<img src="${escapeHtml(user.avatarUrl)}" class="h-12 w-12 rounded-full" />` : '<div class="h-12 w-12 rounded-full bg-theme-surface-hover"></div>'}
        <div class="flex-1 min-w-0">
          <a href="${escapeHtml(user.siteUrl || '#')}" target="_blank" class="font-medium hover:underline">${escapeHtml(user.displayName || user.username)}</a>
          <p class="text-sm text-theme-muted">@${escapeHtml(user.username)}</p>
          ${user.bio ? `<p class="text-sm text-theme-faint mt-1 truncate">${escapeHtml(user.bio)}</p>` : ''}
        </div>
        <div class="text-right text-xs text-theme-faint">
          <div>${user._count?.posts || 0} posts</div>
          <div>${user._count?.followers || 0} followers</div>
        </div>
        ${token ? `<button class="follow-btn rounded bg-theme-surface-hover px-3 py-1 text-xs hover:bg-theme-card-hover transition" data-user-id="${user.id}">Follow</button>` : ''}
      </div>`;
  }

  function renderFeedCard(feed) {
    const subbed = isSubscribed(feed.uri);
    return `
      <div class="feed-card flex items-center gap-4 rounded-lg border border-theme-card-border bg-theme-card p-4 cursor-pointer hover:border-theme-card-hover transition" data-feed-uri="${escapeHtml(feed.uri || '')}" data-feed-name="${escapeHtml(feed.displayName || 'Feed')}" data-feed-avatar="${escapeHtml(feed.avatar || '')}">
        ${feed.avatar ? `<img src="${escapeHtml(feed.avatar)}" class="h-12 w-12 rounded-lg" />` : '<div class="h-12 w-12 rounded-lg bg-theme-surface-hover flex items-center justify-center text-theme-muted">📡</div>'}
        <div class="flex-1 min-w-0">
          <span class="font-medium text-sm">${escapeHtml(feed.displayName || 'Untitled Feed')}</span>
          ${feed.description ? `<p class="text-sm text-theme-faint mt-1 line-clamp-2">${escapeHtml(feed.description)}</p>` : ''}
          <p class="text-xs text-theme-faint mt-1">by @${escapeHtml(feed.creator?.handle || '')}</p>
        </div>
        <div class="flex flex-col items-end gap-1 shrink-0">
          <div class="text-xs text-theme-faint">❤ ${feed.likeCount || 0}</div>
          <button class="feed-sub-btn text-xs px-2 py-0.5 rounded ${subbed ? 'bg-red-500/20 text-red-400 hover:bg-red-500/30' : 'bg-theme-primary/20 text-theme-primary hover:bg-theme-primary/30'} transition" data-feed-uri="${escapeHtml(feed.uri || '')}" data-feed-name="${escapeHtml(feed.displayName || 'Feed')}" data-feed-avatar="${escapeHtml(feed.avatar || '')}">${subbed ? '− Remove' : '+ Add'}</button>
          <div class="text-theme-primary text-xs">View →</div>
        </div>
      </div>`;
  }

  // ============================================================
  // SLIDE-OVER PANEL (Thread / Profile)
  // ============================================================
  const slidePanel = document.getElementById('slide-panel');
  const slideContent = document.getElementById('slide-content');
  const slideBody = document.getElementById('slide-body');
  const slideTitle = document.getElementById('slide-title');

  function openSlidePanel(title, html) {
    slideTitle.textContent = title;
    slideBody.innerHTML = html;
    slidePanel.classList.remove('hidden');
    requestAnimationFrame(() => slideContent.style.transform = 'translateX(0)');
    initHlsVideos();
  }

  function closeSlidePanel() {
    slideContent.style.transform = 'translateX(100%)';
    setTimeout(() => slidePanel.classList.add('hidden'), 300);
  }

  document.getElementById('slide-backdrop').addEventListener('click', closeSlidePanel);
  document.getElementById('slide-close').addEventListener('click', closeSlidePanel);

  async function openProfile(handle) {
    openSlidePanel(`@${handle}`, `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`);
    try {
      const profile = await fetchBskyProfile(handle);
      const feedData = await fetchBskyAuthorFeed(handle);
      const posts = (feedData.feed || []).map(item => normalizeBskyPost(item));

      let html = `
        <div class="text-center pb-4 border-b border-theme-border">
          ${profile.banner ? `<div class="-mx-4 -mt-4 mb-4"><img src="${escapeHtml(profile.banner)}" class="w-full h-32 object-cover" /></div>` : ''}
          ${profile.avatar ? `<img src="${escapeHtml(profile.avatar)}" class="h-20 w-20 rounded-full mx-auto border-4 border-theme-bg ${profile.banner ? '-mt-14' : ''}" />` : ''}
          <h3 class="font-bold text-lg mt-2">${escapeHtml(profile.displayName || profile.handle)}</h3>
          <p class="text-sm text-theme-faint">@${escapeHtml(profile.handle)}</p>
          ${profile.description ? `<p class="text-sm text-theme-muted mt-2 text-left">${formatText(profile.description)}</p>` : ''}
          <div class="flex justify-center gap-6 mt-3 text-sm">
            <span><strong>${profile.followersCount || 0}</strong> <span class="text-theme-faint">followers</span></span>
            <span><strong>${profile.followsCount || 0}</strong> <span class="text-theme-faint">following</span></span>
            <span><strong>${profile.postsCount || 0}</strong> <span class="text-theme-faint">posts</span></span>
          </div>
        </div>
        <div class="space-y-4 mt-4">${posts.map(p => renderPostCard(p)).join('')}</div>`;
      slideBody.innerHTML = html;
      attachAllListeners();
      initHlsVideos();
    } catch {
      slideBody.innerHTML = `<div class="text-center py-8 text-red-400">Failed to load profile</div>`;
    }
  }

  async function openThread(uri) {
    openSlidePanel('Thread', `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`);
    try {
      const data = await fetchBskyThread(uri);
      const thread = data.thread;
      if (!thread?.post) { slideBody.innerHTML = '<div class="text-center py-8 text-theme-faint">Thread not found</div>'; return; }

      function renderThreadNode(node, depth = 0) {
        if (!node?.post) return '';
        const post = normalizeBskyPost({ post: node.post });
        const indent = depth > 0 ? `style="margin-left:${Math.min(depth, 4) * 1}rem;border-left:2px solid var(--ps-card-border);padding-left:0.75rem"` : '';
        let html = `<div ${indent}>${renderPostCard(post)}</div>`;
        if (node.replies?.length) {
          html += node.replies.map(r => renderThreadNode(r, depth + 1)).join('');
        }
        return html;
      }

      // Render parent chain if exists
      let parentHtml = '';
      if (thread.parent) {
        const parents = [];
        let p = thread.parent;
        while (p?.post) { parents.unshift(p); p = p.parent; }
        parentHtml = parents.map((n, i) => renderThreadNode(n, 0)).join('');
      }

      const mainPost = thread.post;
      const mainHtml = renderPostCard(normalizeBskyPost({ post: mainPost }));
      const repliesHtml = (thread.replies || []).map(r => renderThreadNode(r, 1)).join('');

      // Find root for reply threading
      let rootUri = mainPost.uri, rootCid = mainPost.cid;
      if (thread.parent) {
        let p = thread.parent;
        while (p?.parent?.post) p = p.parent;
        if (p?.post) { rootUri = p.post.uri; rootCid = p.post.cid; }
      }

      // Track which post is being replied to (default: main post)
      let replyTarget = { uri: mainPost.uri, cid: mainPost.cid, handle: mainPost.author.handle };

      const replyComposer = bskySession?.accessJwt ? `
        <div id="thread-reply-box" class="mt-4 border-t border-theme-border pt-4">
          <div id="thread-reply-label" style="font-size:.75rem;color:var(--ps-text-faint,#888);margin-bottom:.5rem">Replying to @${escapeHtml(mainPost.author.handle)}</div>
          <div class="flex gap-3">
            <div class="flex-1">
              <textarea id="thread-reply-input" rows="3" placeholder="Write a reply..." style="width:100%;background:var(--ps-input-bg,#1a1a2e);border:1px solid var(--ps-input-border,#333);border-radius:.5rem;padding:.75rem;color:var(--ps-text,#e0e0e0);font-size:.875rem;resize:vertical;outline:none" maxlength="300"></textarea>
              <div id="thread-reply-link-preview"></div>
              <div class="flex items-center justify-between mt-2">
                <span id="thread-reply-count" style="font-size:.75rem;color:var(--ps-text-faint,#888)">0/300</span>
                <button id="thread-reply-send" style="background:var(--ps-accent,#3b82f6);color:#fff;border:none;border-radius:.375rem;padding:.375rem 1rem;font-size:.875rem;cursor:pointer;opacity:.5" disabled>Reply</button>
              </div>
            </div>
          </div>
        </div>` : '';

      slideBody.innerHTML = `
        ${parentHtml ? `<div class="space-y-3 opacity-70 mb-4">${parentHtml}</div><div class="border-t border-theme-border pt-4"></div>` : ''}
        <div class="mb-4">${mainHtml}</div>
        ${replyComposer}
        ${repliesHtml ? `<div class="space-y-3 mt-4">${repliesHtml}</div>` : '<div class="text-center py-4 text-theme-faint">No replies yet</div>'}`;

      // Wire reply composer
      const replyInput = document.getElementById('thread-reply-input');
      const replyBtn = document.getElementById('thread-reply-send');
      const replyCount = document.getElementById('thread-reply-count');
      const replyLabel = document.getElementById('thread-reply-label');
      const replyPreviewContainer = document.getElementById('thread-reply-link-preview');
      let getReplyCard = () => null;
      if (replyInput && replyBtn) {
        if (replyPreviewContainer) {
          getReplyCard = setupLinkPreview(replyInput, replyPreviewContainer);
        }
        replyInput.addEventListener('input', () => {
          const len = replyInput.value.length;
          replyCount.textContent = `${len}/300`;
          replyBtn.disabled = len === 0 || len > 300;
          replyBtn.style.opacity = replyBtn.disabled ? '.5' : '1';
        });
        replyBtn.addEventListener('click', async () => {
          const text = replyInput.value.trim();
          if (!text) return;
          replyBtn.disabled = true;
          replyBtn.textContent = 'Sending...';
          try {
            await createBskyRecord(text, { uri: replyTarget.uri, cid: replyTarget.cid, root: { uri: rootUri, cid: rootCid } }, getReplyCard());
            replyInput.value = '';
            replyCount.textContent = '0/300';
            if (replyPreviewContainer) replyPreviewContainer.innerHTML = '';
            replyBtn.textContent = 'Reply';
            // Reload thread to show the new reply
            openThread(uri);
          } catch (err) {
            console.error('Reply error:', err);
            replyBtn.textContent = 'Failed — Retry';
            replyBtn.disabled = false;
            replyBtn.style.opacity = '1';
          }
        });

        // Override reply button behavior inside thread panel — clicking reply on any post
        // in the thread should retarget the composer to that post
        slideBody.querySelectorAll('.bsky-reply-btn').forEach(btn => {
          btn.dataset.bound = '1';
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const article = btn.closest('article');
            if (!article) return;
            const postUri = article.dataset.uri;
            const postCid = article.dataset.cid;
            const handleEl = article.querySelector('.bsky-avatar[data-handle]');
            const handle = handleEl?.dataset.handle || '';
            if (postUri && postCid) {
              replyTarget = { uri: postUri, cid: postCid, handle };
              replyLabel.textContent = `Replying to @${handle}`;
              replyLabel.style.color = 'var(--ps-accent, #3b82f6)';
              replyInput.focus();
              document.getElementById('thread-reply-box')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
          });
        });
      }

      attachAllListeners();
      initHlsVideos();
    } catch {
      slideBody.innerHTML = `<div class="text-center py-8 text-red-400">Failed to load thread</div>`;
    }
  }

  // ============================================================
  // MAIN LOAD LOGIC
  // ============================================================
  const scrollObserver = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !isLoading && hasMore) loadMore();
  }, { rootMargin: '400px' });
  scrollObserver.observe(scrollSentinel);

  function loadMore() {
    if (currentTab === 'timeline') { piratePage++; loadFeedTab(true); }
    else if (currentTab === 'feeds' && activeFeedUri) { loadCustomFeedView(activeFeedUri, activeFeedName, true); }
    else if (currentTab === 'discover' && activeFeedUri) { loadCustomFeedView(activeFeedUri, activeFeedName, true); }
    else if (currentTab === 'discover' && currentDiscoverSub === 'trending') { loadDiscoverTrending(true); }
    else if (currentTab === 'posts') { loadPostsTab(true); }
  }

  // --- Tab switching ---
  document.querySelectorAll('[id^="tab-"]:not(#tab-feeds)').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelector('.active-tab')?.classList.remove('active-tab', 'bg-theme-surface-hover');
      btn.classList.add('active-tab', 'bg-theme-surface-hover');
      document.getElementById('tab-feeds').value = '';
      currentTab = btn.id.replace('tab-', '');
      resetPagination();
      updateUI();
      loadCurrentTab();
    });
  });

  // --- Feeds dropdown ---
  const feedsDropdown = document.getElementById('tab-feeds');

  function populateFeedsDropdown() {
    feedsDropdown.innerHTML = '<option value="" disabled selected>Feeds</option>';
    subscribedFeeds.forEach(f => {
      const opt = document.createElement('option');
      opt.value = f.uri;
      opt.textContent = f.name || 'Untitled Feed';
      feedsDropdown.appendChild(opt);
    });
    feedsDropdown.style.display = subscribedFeeds.length ? '' : 'none';
  }
  populateFeedsDropdown();

  feedsDropdown.addEventListener('change', () => {
    const uri = feedsDropdown.value;
    const feed = subscribedFeeds.find(f => f.uri === uri);
    if (!uri || !feed) return;
    document.querySelector('.active-tab')?.classList.remove('active-tab', 'bg-theme-surface-hover');
    currentTab = 'feeds';
    resetPagination();
    updateUI();
    loadCustomFeedView(uri, feed.name);
  });

  function resetPagination() {
    piratePage = 1;
    bskyCursor = null;
    hasMore = true;
  }

  function updateUI() {
    filterBar.classList.toggle('hidden', currentTab !== 'timeline');
    discoverPills.classList.toggle('hidden', currentTab !== 'discover');
    rssManagement.classList.toggle('hidden', currentTab !== 'rss');
    const composeBox = document.getElementById('compose-box');
    if (composeBox) composeBox.style.display = (currentTab === 'timeline' && bskySession?.accessJwt) ? '' : 'none';
  }

  function loadCurrentTab() {
    if (currentTab === 'timeline') loadFeedTab();
    else if (currentTab === 'discover') loadDiscoverTab();
    else if (currentTab === 'squads') renderSquadsView();
    else if (currentTab === 'posts') loadPostsTab();
    else if (currentTab === 'youtube') loadYouTubeTab();
    else if (currentTab === 'rss') loadRSSTab();
  }

  // --- Filter pills ---
  document.querySelectorAll('.filter-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelector('.filter-pill.active-pill')?.classList.remove('active-pill', 'bg-theme-surface-hover');
      btn.classList.add('active-pill', 'bg-theme-surface-hover');
      currentFilter = btn.dataset.filter;
      resetPagination();
      loadFeedTab();
    });
  });

  // --- Discover pills ---
  document.querySelectorAll('.discover-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelector('.discover-pill.active-pill')?.classList.remove('active-pill', 'bg-theme-surface-hover');
      btn.classList.add('active-pill', 'bg-theme-surface-hover');
      currentDiscoverSub = btn.dataset.sub;
      resetPagination();
      loadDiscoverTab();
    });
  });

  // --- Search ---
  document.querySelectorAll('.search-type-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelector('.search-type-pill.active-pill')?.classList.remove('active-pill', 'bg-theme-surface-hover');
      btn.classList.add('active-pill', 'bg-theme-surface-hover');
      currentSearchType = btn.dataset.type;
      resetPagination();
      const q = document.getElementById('search-input').value.trim();
      if (q) loadSearchResults();
    });
  });

  document.getElementById('search-btn')?.addEventListener('click', () => {
    resetPagination();
    loadSearchResults();
  });

  document.getElementById('search-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { resetPagination(); loadSearchResults(); }
  });

  document.getElementById('social-login')?.addEventListener('click', () => {
    window.location.href = `${hubUrl}/api/auth/github`;
  });

  // ============================================================
  // FEED TAB — Bluesky timeline + Pirate RSS merged
  // ============================================================
  async function loadFeedTab(append = false) {
    if (isLoading) return;
    isLoading = true;
    if (!append) { feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`; }
    scrollSentinel.classList.toggle('hidden', !append);

    try {
      const session = await ensureBskySession();
      let allPosts = [];
      let hasBlueskyError = false;

      // Fetch Bluesky timeline (direct AT Protocol)
      if (session?.accessJwt) {
        try {
          const bskyData = await fetchBskyTimeline(bskyCursor);
          bskyCursor = bskyData.cursor || null;
          const bskyPosts = (bskyData.feed || []).map(item => normalizeBskyPost(item));
          allPosts.push(...bskyPosts);
        } catch (err) {
          console.error('[PS] Bluesky timeline error:', err.message);
          hasBlueskyError = true;
        }
      }

      // Fetch squad member posts and merge into timeline
      if (session?.accessJwt && !append) {
        try {
          if (!allSquads.length && token) {
            const sRes = await fetchTimeout(`${hubUrl}/api/bluesky-feed/squads`, { headers: { Authorization: `Bearer ${token}` } });
            allSquads = await sRes.json();
          }
          if (allSquads.length) {
            // Build squad member lookup: handle -> border color
            squadMemberHandles = new Map();
            for (const squad of allSquads) {
              const color = squad.borderColor || '#eab308';
              for (const m of (squad.members || [])) {
                if (!squadMemberHandles.has(m.handle)) squadMemberHandles.set(m.handle, color);
              }
            }
            const seenDids = new Set();
            const uniqueMembers = [];
            for (const squad of allSquads) {
              if (squad.feedEnabled === false) continue;
              for (const m of (squad.members || [])) {
                const key = m.did || m.handle;
                if (!seenDids.has(key)) { seenDids.add(key); uniqueMembers.push(m); }
              }
            }
            if (uniqueMembers.length) {
              const squadPosts = await fetchSquadFeedDirect(uniqueMembers);
              // Deduplicate — skip posts already in timeline
              const existingUris = new Set(allPosts.map(p => p.uri));
              allPosts.push(...squadPosts.filter(p => !existingUris.has(p.uri)));
            }
          }
        } catch (err) {
          console.error('[PS] Squad feed merge error:', err.message);
          hasBlueskyError = true;
        }
      }

      // Fetch Pirate Social timeline (RSS + pirate posts) — only on first load or if filter is pirate
      if (token && (!append || currentFilter === 'pirate' || currentFilter === 'all')) {
        try {
          const headers = { Authorization: `Bearer ${token}` };
          const pirateRes = await fetchTimeout(`${hubUrl}/api/timeline?page=${piratePage}`, { headers });
          const pirateData = await pirateRes.json();
          const piratePosts = (pirateData.posts || []).map(p => normalizePiratePost(p));
          allPosts.push(...piratePosts);
          if (!pirateData.hasMore && !bskyCursor) hasMore = false;
        } catch (err) {
          console.error('[PS] Pirate timeline error:', err.message);
        }
      }

      // If no Bluesky session and no token, show discover
      if (!session?.accessJwt && !token) {
        try {
          const pirateRes = await fetchTimeout(`${hubUrl}/api/timeline/discover?page=${piratePage}`);
          const pirateData = await pirateRes.json();
          allPosts = (pirateData.posts || []).map(p => normalizePiratePost(p));
          hasMore = !!pirateData.hasMore;
        } catch {}
      }

      // Sort by date
      allPosts.sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));

      // Apply filter
      const filtered = allPosts.filter(p => matchesFilter(p, currentFilter));

      hasMore = !!bskyCursor || hasMore;

      const html = filtered.map(p => renderPostCard(p)).join('');
      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', html);
      } else {
        if (!filtered.length && !session?.accessJwt && !token) {
          feedContainer.innerHTML = `<div class="text-center text-theme-faint py-12"><p>${L.signInPrompt || 'Sign in to see your feed'}</p><button id="social-login" class="mt-4 rounded bg-theme-primary text-white px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">${L.signInButton || 'Sign in with GitHub'}</button></div>`;
          document.getElementById('social-login')?.addEventListener('click', () => { window.location.href = `${hubUrl}/api/auth/github`; });
        } else if (!filtered.length) {
          if (hasBlueskyError) {
            feedContainer.innerHTML = `<div class="text-center py-8"><div class="text-theme-faint mb-3">⚠️ Unable to load Bluesky feed</div><p class="text-sm text-theme-muted mb-4">Try connecting Bluesky in Settings or refreshing the page</p><button id="refresh-feed" class="rounded bg-theme-primary px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">↻ Retry</button></div>`;
            document.getElementById('refresh-feed')?.addEventListener('click', loadFeedTab);
          } else {
            feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${session?.accessJwt ? (L.noPosts || 'No posts yet') : (L.connectBluesky || 'Connect Bluesky in Settings to see your feed')}</div>`;
          }
        } else {
          feedContainer.innerHTML = html;
        }
      }
      attachAllListeners();
      initHlsVideos();
    } catch (err) {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load feed'}: ${err.message}</div>`;
      hasMore = false;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // DISCOVER TAB
  // ============================================================
  async function loadDiscoverTab() {
    if (currentDiscoverSub === 'trending') loadDiscoverTrending();
    else if (currentDiscoverSub === 'people') loadDiscoverPeople();
    else if (currentDiscoverSub === 'feeds') loadDiscoverFeeds();
  }

  async function loadDiscoverTrending(append = false) {
    if (isLoading) return;
    isLoading = true;
    if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`;
    scrollSentinel.classList.toggle('hidden', !append);

    try {
      const session = await ensureBskySession();
      let allPosts = [];

      // Trending topics banner
      let trendingHtml = '';
      if (!append) {
        try {
          const trending = await fetchTrendingTopics();
          if (trending.topics?.length || trending.suggested?.length) {
            const topics = [...(trending.topics || []), ...(trending.suggested || [])].slice(0, 12);
            trendingHtml = `<div class="flex gap-2 flex-wrap mb-6">${topics.map(t =>
              `<button class="trending-topic rounded-full bg-theme-input-bg border border-theme-input-border px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-topic="${escapeHtml(t.topic || t.tag || t)}">#${escapeHtml(t.topic || t.tag || t)}</button>`
            ).join('')}</div>`;
          }
        } catch {}
      }

      // Bluesky discover feed
      if (session?.accessJwt) {
        try {
          const data = await fetchBskyDiscover(bskyCursor);
          bskyCursor = data.cursor || null;
          allPosts = (data.feed || []).map(item => normalizeBskyPost(item));
        } catch {}
      }

      // Also pull Pirate Social discover
      try {
        const pirateRes = await fetchTimeout(`${hubUrl}/api/timeline/discover?page=${piratePage}`);
        const pirateData = await pirateRes.json();
        allPosts.push(...(pirateData.posts || []).map(p => normalizePiratePost(p)));
      } catch {}

      allPosts.sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));
      hasMore = !!bskyCursor;

      const html = allPosts.map(p => renderPostCard(p)).join('');
      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', html);
      } else {
        feedContainer.innerHTML = trendingHtml + (html || `<div class="text-center py-8 text-theme-faint">${L.noPosts || 'No posts'}</div>`);
      }
      attachAllListeners();
      initHlsVideos();

      // Attach trending topic click handlers — search posts for that topic
      document.querySelectorAll('.trending-topic').forEach(btn => {
        btn.addEventListener('click', async () => {
          const topic = btn.dataset.topic;
          if (!topic) return;
          feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`;
          try {
            const data = await searchBskyPosts(topic);
            const posts = (data.posts || []).map(p => normalizeBskyPost({ post: p }));
            const backBtn = `<button id="back-to-discover" class="flex items-center gap-1 text-sm text-theme-muted hover:text-theme-text transition mb-4">← Back to discover</button>
              <h2 class="text-lg font-semibold mb-4">#${escapeHtml(topic)}</h2>`;
            feedContainer.innerHTML = backBtn + (posts.map(p => renderPostCard(p)).join('') || `<div class="text-center py-8 text-theme-faint">No posts found</div>`);
            document.getElementById('back-to-discover')?.addEventListener('click', () => {
              resetPagination();
              loadDiscoverTrending();
            });
            attachAllListeners();
            initHlsVideos();
          } catch {
            feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">Search failed</div>`;
          }
        });
      });
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  async function loadDiscoverPeople() {
    feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`;
    hasMore = false;
    scrollSentinel.classList.add('hidden');

    try {
      // Fetch Pirate Social directory
      const headers = token ? { Authorization: `Bearer ${token}` } : {};
      const res = await fetchTimeout(`${hubUrl}/api/directory?page=1`, { headers });
      const data = await res.json();
      const html = (data.users || []).map(u => renderPirateUserCard(u)).join('');
      feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">${L.noUsers || 'No users yet'}</div>`;
      attachAllListeners();
    } catch {
      feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
    } finally { isLoading = false; }
  }

  async function loadDiscoverFeeds() {
    feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`;
    hasMore = false;
    scrollSentinel.classList.add('hidden');

    try {
      const data = await searchBskyFeeds('');
      const feeds = data.feeds || [];
      const html = feeds.map(f => renderFeedCard(f)).join('');
      feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No feeds found</div>`;
      attachAllListeners();
    } catch {
      feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
    } finally { isLoading = false; }
  }

  let activeFeedUri = null;
  let activeFeedName = null;

  async function loadCustomFeedView(feedUri, feedName, append = false) {
    activeFeedUri = feedUri;
    activeFeedName = feedName;
    if (isLoading) return;
    isLoading = true;
    if (!append) {
      feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`;
    }

    try {
      const data = await fetchCustomFeed(feedUri, bskyCursor);
      bskyCursor = data.cursor || null;
      hasMore = !!bskyCursor;
      const posts = (data.feed || []).map(item => normalizeBskyPost(item));
      const html = posts.map(p => renderPostCard(p)).join('');

      const subbed = isSubscribed(feedUri);
      const subBtn = `<button id="feed-view-sub" class="text-xs px-2 py-0.5 rounded ${subbed ? 'bg-red-500/20 text-red-400 hover:bg-red-500/30' : 'bg-theme-primary/20 text-theme-primary hover:bg-theme-primary/30'} transition ml-2">${subbed ? '− Remove from Feeds' : '+ Add to Feeds'}</button>`;
      const backLabel = currentTab === 'feeds' ? '← Back' : '← Back to feeds';
      const backBtn = `<div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <button id="back-to-feeds" class="flex items-center gap-1 text-sm text-theme-muted hover:text-theme-text transition">${backLabel}</button>
          <h2 class="text-lg font-semibold">${escapeHtml(feedName)}</h2>
        </div>
        ${subBtn}
      </div>`;

      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', html);
      } else {
        feedContainer.innerHTML = backBtn + (html || `<div class="text-center py-8 text-theme-faint">${L.noPosts || 'No posts'}</div>`);
        document.getElementById('back-to-feeds')?.addEventListener('click', () => {
          activeFeedUri = null;
          resetPagination();
          if (currentTab === 'feeds') {
            // Go back to timeline
            document.querySelector('.active-tab')?.classList.remove('active-tab', 'bg-theme-surface-hover');
            document.getElementById('tab-timeline').classList.add('active-tab', 'bg-theme-surface-hover');
            feedsDropdown.value = '';
            currentTab = 'timeline';
            updateUI();
            loadFeedTab();
          } else {
            loadDiscoverFeeds();
          }
        });
        document.getElementById('feed-view-sub')?.addEventListener('click', (e) => {
          if (isSubscribed(feedUri)) {
            unsubscribeFeed(feedUri);
            e.target.textContent = '+ Add to Feeds';
            e.target.className = e.target.className.replace(/bg-red-500\/20 text-red-400 hover:bg-red-500\/30/, 'bg-theme-primary/20 text-theme-primary hover:bg-theme-primary/30');
          } else {
            subscribeFeed(feedUri, feedName, '');
            e.target.textContent = '− Remove from Feeds';
            e.target.className = e.target.className.replace(/bg-theme-primary\/20 text-theme-primary hover:bg-theme-primary\/30/, 'bg-red-500/20 text-red-400 hover:bg-red-500/30');
          }
        });
      }
      attachAllListeners();
      initHlsVideos();
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // SEARCH TAB
  // ============================================================
  async function loadSearchResults(append = false) {
    const query = document.getElementById('search-input').value.trim();
    if (!query) return;
    if (isLoading) return;
    isLoading = true;
    if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading || 'Loading...'}</div>`;

    try {
      if (currentSearchType === 'posts') {
        const data = await searchBskyPosts(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const posts = (data.posts || []).map(p => normalizeBskyPost({ post: p }));
        const html = posts.map(p => renderPostCard(p)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No results for "${escapeHtml(query)}"</div>`;
      } else if (currentSearchType === 'users') {
        const data = await searchBskyActors(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const html = (data.actors || []).map(a => renderBskyUserCard(a)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No users found for "${escapeHtml(query)}"</div>`;
      } else if (currentSearchType === 'feeds') {
        const data = await searchBskyFeeds(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const html = (data.feeds || []).map(f => renderFeedCard(f)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No feeds found for "${escapeHtml(query)}"</div>`;
      }
      attachAllListeners();
      initHlsVideos();
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">Search failed</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // INTERACTIONS
  // ============================================================
  function attachAllListeners() {
    // Bluesky likes
    document.querySelectorAll('.bsky-like-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!bskySession?.accessJwt) return;
        const uri = btn.dataset.uri;
        const cid = btn.dataset.cid;
        const countEl = btn.querySelector('.like-count');
        const count = parseInt(countEl.textContent) || 0;
        if (myLikes[uri]) {
          // Unlike
          btn.classList.remove('text-red-400');
          btn.innerHTML = `${ICON.heart} <span class="like-count">${Math.max(0, count - 1)}</span>`;
          try { await unlikeBskyPost(uri); } catch { btn.classList.add('text-red-400'); btn.innerHTML = `${ICON.heartFill} <span class="like-count">${count}</span>`; }
        } else {
          // Like
          btn.classList.add('text-red-400');
          btn.innerHTML = `${ICON.heartFill} <span class="like-count">${count + 1}</span>`;
          try { await likeBskyPost(uri, cid); } catch { btn.classList.remove('text-red-400'); btn.innerHTML = `${ICON.heart} <span class="like-count">${count}</span>`; }
        }
      });
    });

    // Bluesky reposts
    document.querySelectorAll('.bsky-repost-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!bskySession?.accessJwt) return;
        const uri = btn.dataset.uri;
        const cid = btn.dataset.cid;
        const countEl = btn.querySelector('.repost-count');
        const count = parseInt(countEl.textContent) || 0;
        if (myReposts[uri]) {
          btn.classList.remove('text-green-400');
          btn.innerHTML = `${ICON.repost} <span class="repost-count">${Math.max(0, count - 1)}</span>`;
          try { await unrepostBskyPost(uri); } catch { btn.classList.add('text-green-400'); btn.innerHTML = `${ICON.repost} <span class="repost-count">${count}</span>`; }
        } else {
          btn.classList.add('text-green-400');
          btn.innerHTML = `${ICON.repost} <span class="repost-count">${count + 1}</span>`;
          try { await repostBskyPost(uri, cid); } catch { btn.classList.remove('text-green-400'); btn.innerHTML = `${ICON.repost} <span class="repost-count">${count}</span>`; }
        }
      });
    });

    // Reply button → open thread
    document.querySelectorAll('.bsky-reply-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => openThread(btn.dataset.uri));
    });

    // Avatar click → open profile
    document.querySelectorAll('.bsky-avatar:not([data-bound])').forEach(el => {
      el.dataset.bound = '1';
      el.addEventListener('click', (e) => { e.preventDefault(); openProfile(el.dataset.handle); });
    });

    // Pirate Social likes
    document.querySelectorAll('.like-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!token) return alert('Sign in to like posts');
        const postId = btn.dataset.postId;
        const isLiked = btn.classList.contains('text-red-400');
        const method = isLiked ? 'DELETE' : 'POST';
        const res = await fetch(`${hubUrl}/api/interactions/like`, {
          method, headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId }),
        });
        const data = await res.json();
        btn.innerHTML = `${data.liked ? ICON.heartFill : ICON.heart} ${data.count}`;
        btn.classList.toggle('text-red-400', data.liked);
      });
    });

    // Pirate Social follows
    document.querySelectorAll('.follow-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!token) return;
        const userId = btn.dataset.userId;
        const res = await fetch(`${hubUrl}/api/interactions/follow`, {
          method: 'POST', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId }),
        });
        const data = await res.json();
        btn.textContent = data.following ? 'Following' : 'Follow';
      });
    });

    // Share buttons
    document.querySelectorAll('.share-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => openShareModal(btn.dataset.url, btn.dataset.title));
    });

    // Feed cards — click to load that feed posts
    document.querySelectorAll('.feed-card:not([data-bound])').forEach(card => {
      card.dataset.bound = '1';
      card.addEventListener('click', (e) => {
        if (e.target.closest('.feed-sub-btn')) return; // Don't navigate when clicking subscribe
        const uri = card.dataset.feedUri;
        const name = card.dataset.feedName;
        if (uri) loadCustomFeedView(uri, name);
      });
    });

    // Feed subscribe/unsubscribe buttons
    document.querySelectorAll('.feed-sub-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const uri = btn.dataset.feedUri;
        const name = btn.dataset.feedName;
        const avatar = btn.dataset.feedAvatar;
        if (isSubscribed(uri)) {
          unsubscribeFeed(uri);
          btn.textContent = '+ Add';
          btn.className = btn.className.replace(/bg-red-500\/20 text-red-400 hover:bg-red-500\/30/, 'bg-theme-primary/20 text-theme-primary hover:bg-theme-primary/30');
        } else {
          subscribeFeed(uri, name, avatar);
          btn.textContent = '− Remove';
          btn.className = btn.className.replace(/bg-theme-primary\/20 text-theme-primary hover:bg-theme-primary\/30/, 'bg-red-500/20 text-red-400 hover:bg-red-500/30');
        }
      });
    });

    // Squad add-from-post button
    document.querySelectorAll('.bsky-squad-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        if (!token) return alert('Sign in to manage squads');
        const handle = btn.dataset.handle;
        // Remove any existing dropdown
        document.querySelectorAll('.squad-picker').forEach(el => el.remove());
        try {
          const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, { headers: { Authorization: `Bearer ${token}` } });
          const squads = await res.json();
          if (!squads.length) return alert('Create a squad first in the Squads tab');
          const rect = btn.getBoundingClientRect();
          const picker = document.createElement('div');
          picker.className = 'squad-picker';
          picker.style.cssText = `position:fixed;left:${rect.left}px;top:${rect.bottom + 4}px;z-index:70;background:var(--ps-card-bg, #1a1a2e);border:1px solid var(--ps-card-border, #333);border-radius:.5rem;padding:.25rem 0;min-width:10rem;box-shadow:0 4px 12px rgba(0,0,0,.4)`;
          squads.forEach(sq => {
            const item = document.createElement('button');
            item.style.cssText = 'display:block;width:100%;text-align:left;padding:.5rem .75rem;background:none;border:none;color:var(--ps-text, #e0e0e0);cursor:pointer;font-size:.8rem';
            item.textContent = sq.name;
            item.addEventListener('mouseenter', () => item.style.background = 'var(--ps-surface-hover, rgba(255,255,255,.1))');
            item.addEventListener('mouseleave', () => item.style.background = 'none');
            item.addEventListener('click', async () => {
              picker.remove();
              const addRes = await fetch(`${hubUrl}/api/bluesky-feed/squads/${sq.id}/members`, {
                method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body: JSON.stringify({ handle }),
              });
              if (addRes.ok) { btn.style.color = 'var(--ps-accent, #22c55e)'; }
              else { const err = await addRes.json().catch(() => ({})); alert(err.error || 'Failed to add'); }
            });
            picker.appendChild(item);
          });
          document.body.appendChild(picker);
          const closePicker = (ev) => { if (!picker.contains(ev.target) && ev.target !== btn) { picker.remove(); document.removeEventListener('click', closePicker); } };
          setTimeout(() => document.addEventListener('click', closePicker), 0);
        } catch (err) { console.error('Squad picker error:', err); }
      });
    });

    // Clickable post images → lightbox
    document.querySelectorAll('.post-img:not([data-bound])').forEach(img => {
      img.dataset.bound = '1';
      img.addEventListener('click', (e) => {
        e.stopPropagation();
        // Gather sibling images in the same gallery group
        const article = img.closest('article');
        const siblings = article ? [...article.querySelectorAll('.post-img')] : [img];
        const images = siblings.map(el => ({ src: el.dataset.full || el.src, alt: el.dataset.alt || el.alt || '' }));
        const idx = siblings.indexOf(img);
        openLightbox(images, idx >= 0 ? idx : 0);
      });
    });
  }

  // ============================================================
  // SHARE MODAL
  // ============================================================
  const shareOverlay = document.createElement('div');
  shareOverlay.id = 'share-modal-overlay';
  shareOverlay.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:60;justify-content:center;align-items:center';
  shareOverlay.innerHTML = `
    <div id="share-modal" style="background:var(--ps-card-bg);border:1px solid var(--ps-card-border);border-radius:.75rem;padding:1.5rem;width:20rem;max-width:90vw">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
        <h3 style="font-weight:600;font-size:1rem">Share</h3>
        <button id="share-close" style="color:var(--ps-text-muted);font-size:1.25rem;cursor:pointer;background:none;border:none">✕</button>
      </div>
      <div id="share-links" style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem"></div>
    </div>`;
  document.body.appendChild(shareOverlay);
  shareOverlay.addEventListener('click', (e) => { if (e.target === shareOverlay) shareOverlay.style.display = 'none'; });
  document.getElementById('share-close').addEventListener('click', () => shareOverlay.style.display = 'none');

  // ============================================================
  // IMAGE LIGHTBOX
  // ============================================================
  const lightbox = document.createElement('div');
  lightbox.id = 'img-lightbox';
  lightbox.style.cssText = 'display:none;position:fixed;inset:0;z-index:80;background:rgba(0,0,0,.92);justify-content:center;align-items:center;cursor:zoom-out';
  lightbox.innerHTML = `
    <button style="position:absolute;top:1rem;right:1rem;background:none;border:none;color:#fff;font-size:1.75rem;cursor:pointer;opacity:.8;z-index:2;line-height:1" aria-label="Close" data-lb-close>✕</button>
    <button style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.15);color:#fff;border:none;font-size:2.5rem;padding:.1rem .7rem;border-radius:.5rem;cursor:pointer;opacity:.8;z-index:2;line-height:1" aria-label="Previous" data-lb-prev>‹</button>
    <img src="" alt="" style="max-width:95vw;max-height:95vh;object-fit:contain;border-radius:.25rem" />
    <button style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.15);color:#fff;border:none;font-size:2.5rem;padding:.1rem .7rem;border-radius:.5rem;cursor:pointer;opacity:.8;z-index:2;line-height:1" aria-label="Next" data-lb-next>›</button>
    <div style="position:absolute;bottom:1rem;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.7);font-size:.8rem" data-lb-counter></div>`;
  document.body.appendChild(lightbox);

  let lbImages = [];
  let lbIndex = 0;

  function openLightbox(images, startIndex) {
    lbImages = images;
    lbIndex = startIndex || 0;
    updateLightbox();
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function updateLightbox() {
    const img = lightbox.querySelector('img');
    img.src = lbImages[lbIndex].src;
    img.alt = lbImages[lbIndex].alt || '';
    const counter = lightbox.querySelector('[data-lb-counter]');
    counter.textContent = lbImages.length > 1 ? `${lbIndex + 1} / ${lbImages.length}` : '';
    lightbox.querySelector('[data-lb-prev]').style.display = lbImages.length > 1 ? '' : 'none';
    lightbox.querySelector('[data-lb-next]').style.display = lbImages.length > 1 ? '' : 'none';
  }

  function closeLightbox() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  lightbox.querySelector('[data-lb-close]').addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });
  lightbox.querySelector('[data-lb-prev]').addEventListener('click', (e) => { e.stopPropagation(); lbIndex = (lbIndex - 1 + lbImages.length) % lbImages.length; updateLightbox(); });
  lightbox.querySelector('[data-lb-next]').addEventListener('click', (e) => { e.stopPropagation(); lbIndex = (lbIndex + 1) % lbImages.length; updateLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (lightbox.style.display !== 'flex') return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') { lbIndex = (lbIndex - 1 + lbImages.length) % lbImages.length; updateLightbox(); }
    if (e.key === 'ArrowRight') { lbIndex = (lbIndex + 1) % lbImages.length; updateLightbox(); }
  });

  function openShareModal(url, title) {
    const enc = encodeURIComponent;
    const links = [
      { label: '𝕏 Twitter', href: `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}` },
      { label: '📘 Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}` },
      { label: '💼 LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}` },
      { label: '📌 Pinterest', href: `https://pinterest.com/pin/create/button/?url=${enc(url)}&description=${enc(title)}` },
      { label: '🔗 Reddit', href: `https://www.reddit.com/submit?url=${enc(url)}&title=${enc(title)}` },
      { label: '📧 Email', href: `mailto:?subject=${enc(title)}&body=${enc(url)}` },
    ];
    const linksHtml = links.map(l =>
      `<a href="${l.href}" target="_blank" rel="noopener noreferrer" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:var(--ps-input-bg);color:var(--ps-text);font-size:.875rem;text-decoration:none;transition:background .15s" onmouseover="this.style.background='var(--ps-surface-hover)'" onmouseout="this.style.background='var(--ps-input-bg)'">${l.label}</a>`
    ).join('');
    const copyBtn = `<button id="share-copy" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:var(--ps-input-bg);color:var(--ps-text);font-size:.875rem;border:none;cursor:pointer;transition:background .15s;grid-column:span 2">📋 Copy Link</button>`;
    document.getElementById('share-links').innerHTML = linksHtml + copyBtn;
    document.getElementById('share-copy').addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(url); document.getElementById('share-copy').textContent = '✓ Copied!'; setTimeout(() => document.getElementById('share-copy').textContent = '📋 Copy Link', 2000); } catch {}
    });
    shareOverlay.style.display = 'flex';
  }

  // ============================================================
  // HLS VIDEO INIT
  // ============================================================
  function initHlsVideos() {
    document.querySelectorAll('video[data-hls]').forEach(video => {
      if (video._hlsInit) return;
      video._hlsInit = true;
      const src = video.dataset.hls;
      if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = src;
      } else if (typeof Hls !== 'undefined' && Hls.isSupported()) {
        const hls = new Hls();
        hls.loadSource(src);
        hls.attachMedia(video);
      }
    });
    observeVideos();
    initYTPlaceholders();
  }

  // ============================================================
  // VIDEO MINI-PLAYER (scroll-away → floating PiP)
  // ============================================================
  let miniPlayerEl = null;
  let miniPlayerSource = null; // the original container
  let miniPlayerDrag = { active: false, offsetX: 0, offsetY: 0 };

  function createMiniPlayer() {
    if (miniPlayerEl) return;
    miniPlayerEl = document.createElement('div');
    miniPlayerEl.id = 'mini-player';
    const savedX = socialSettings.miniPlayerX;
    const savedY = socialSettings.miniPlayerY;
    const defaultRight = 16;
    const defaultBottom = 16;
    miniPlayerEl.style.cssText = `position:fixed;z-index:9999;width:320px;border-radius:.5rem;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.5);border:2px solid var(--ps-card-border,#333);background:#000;transition:none;${
      savedX != null && savedY != null
        ? `left:${Math.min(savedX, window.innerWidth - 340)}px;top:${Math.min(savedY, window.innerHeight - 200)}px`
        : `right:${defaultRight}px;bottom:${defaultBottom}px`
    }`;

    // Drag handle bar at top
    const dragBar = document.createElement('div');
    dragBar.style.cssText = 'height:28px;background:rgba(0,0,0,.8);display:flex;align-items:center;justify-content:space-between;padding:0 6px;cursor:grab;user-select:none';
    // Back-to-post button
    const backBtn = document.createElement('button');
    backBtn.innerHTML = '↩';
    backBtn.title = 'Scroll to post';
    backBtn.style.cssText = 'background:none;color:#fff;border:none;font-size:14px;cursor:pointer;padding:0 4px;line-height:1';
    backBtn.addEventListener('click', (e) => { e.stopPropagation(); returnToPost(); });
    dragBar.appendChild(backBtn);
    // Drag indicator dots
    const dots = document.createElement('span');
    dots.textContent = '⠿⠿⠿';
    dots.style.cssText = 'color:rgba(255,255,255,.4);font-size:10px;letter-spacing:2px';
    dragBar.appendChild(dots);
    // Close button
    const closeBtn = document.createElement('button');
    closeBtn.innerHTML = '\u2715';
    closeBtn.style.cssText = 'background:none;color:#fff;border:none;font-size:14px;cursor:pointer;padding:0 4px;line-height:1';
    closeBtn.addEventListener('click', (e) => { e.stopPropagation(); closeMiniPlayer(); });
    dragBar.appendChild(closeBtn);
    miniPlayerEl.appendChild(dragBar);

    // Media container
    const mediaWrap = document.createElement('div');
    mediaWrap.style.cssText = 'aspect-ratio:16/9;width:100%';
    mediaWrap.id = 'mini-player-media';
    miniPlayerEl.appendChild(mediaWrap);

    // Drag — only from the drag bar
    dragBar.addEventListener('mousedown', startDrag);
    dragBar.addEventListener('touchstart', startDrag, { passive: false });
    document.addEventListener('mousemove', onDrag);
    document.addEventListener('touchmove', onDrag, { passive: false });
    document.addEventListener('mouseup', endDrag);
    document.addEventListener('touchend', endDrag);

    document.body.appendChild(miniPlayerEl);
  }

  function startDrag(e) {
    if (e.target.tagName === 'BUTTON') return;
    miniPlayerDrag.active = true;
    if (miniPlayerEl) miniPlayerEl.style.cursor = 'grabbing';
    const rect = miniPlayerEl.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    miniPlayerDrag.offsetX = clientX - rect.left;
    miniPlayerDrag.offsetY = clientY - rect.top;
    // Remove right/bottom positioning, switch to left/top
    miniPlayerEl.style.right = '';
    miniPlayerEl.style.bottom = '';
    if (e.cancelable) e.preventDefault();
  }

  function onDrag(e) {
    if (!miniPlayerDrag.active) return;
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    const x = Math.max(0, Math.min(clientX - miniPlayerDrag.offsetX, window.innerWidth - 340));
    const y = Math.max(0, Math.min(clientY - miniPlayerDrag.offsetY, window.innerHeight - 200));
    miniPlayerEl.style.left = x + 'px';
    miniPlayerEl.style.top = y + 'px';
    if (e.cancelable) e.preventDefault();
  }

  function endDrag() {
    if (!miniPlayerDrag.active) return;
    miniPlayerDrag.active = false;
    miniPlayerEl.style.cursor = 'grab';
    // Save position
    socialSettings.miniPlayerX = parseInt(miniPlayerEl.style.left);
    socialSettings.miniPlayerY = parseInt(miniPlayerEl.style.top);
    saveSocialSettings();
  }

  function closeMiniPlayer() {
    if (!miniPlayerEl) return;
    const mediaWrap = document.getElementById('mini-player-media');
    const isYT = miniPlayerSource && ytActiveContainer === miniPlayerSource;

    if (isYT) {
      // YouTube: don't move iframe — just pause and reposition wrapper back, then hide
      pauseYTPlayer();
      if (ytSharedIframe) ytSharedIframe._userActivated = false;
      hideYTWrapper();
      if (ytWrapper) ytWrapper._miniPlayerMode = false;
      miniPlayerSource.style.display = '';
    } else {
      // HLS/native video: move content back to original container
      const content = mediaWrap?.querySelector('video');
      if (content) {
        content.pause();
        content._wasPlaying = false;
        if (miniPlayerSource) {
          miniPlayerSource.innerHTML = '';
          miniPlayerSource.appendChild(content);
          content.style.cssText = 'width:100%;height:100%';
          content.classList.add('w-full', 'h-full');
          miniPlayerSource.style.display = '';
        }
      }
    }

    miniPlayerEl.remove();
    miniPlayerEl = null;
    miniPlayerSource = null;
  }

  function returnToPost() {
    if (miniPlayerSource) {
      const source = miniPlayerSource;
      closeMiniPlayer();
      source.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  function activateMiniPlayer(mediaContainer) {
    if (!socialSettings.miniPlayerEnabled) return;
    const isYT = mediaContainer === ytActiveContainer;
    const content = isYT ? ytSharedIframe : mediaContainer.querySelector('video');
    if (!content) return;
    // For native videos, only mini-player if playing
    if (!isYT && content.tagName === 'VIDEO' && content.paused) return;

    createMiniPlayer();
    miniPlayerSource = mediaContainer;

    if (isYT) {
      // YouTube: reposition the wrapper to the mini-player media area instead of moving iframe
      const mediaWrap = document.getElementById('mini-player-media');
      ytStopTracking(); // stop following the container
      ytWrapper._miniPlayerMode = true;
      // Position wrapper inside the mini-player by tracking mini-player-media
      function updateMiniPos() {
        if (!miniPlayerEl || !ytWrapper._miniPlayerMode) return;
        const rect = mediaWrap.getBoundingClientRect();
        ytWrapper.style.left = rect.left + 'px';
        ytWrapper.style.top = rect.top + 'px';
        ytWrapper.style.width = rect.width + 'px';
        ytWrapper.style.height = rect.height + 'px';
        ytWrapper.style.display = '';
        ytWrapper.style.zIndex = '10000';
        ytPositionRAF = requestAnimationFrame(updateMiniPos);
      }
      ytPositionRAF = requestAnimationFrame(updateMiniPos);
      mediaContainer.style.display = 'none';
    } else {
      // Native video: move into mini-player as before
      const mediaWrap = document.getElementById('mini-player-media');
      content.style.cssText = 'width:100%;height:100%;border:none';
      content.className = '';
      mediaWrap.appendChild(content);
      mediaContainer.style.display = 'none';
    }
  }

  function deactivateMiniPlayer(mediaContainer) {
    if (miniPlayerSource !== mediaContainer) return;
    const isYT = mediaContainer === ytActiveContainer;

    if (isYT && ytWrapper) {
      // YouTube: reposition wrapper back over the inline container
      ytWrapper._miniPlayerMode = false;
      ytWrapper.style.zIndex = '40';
      mediaContainer.style.display = '';
      ytPositionOver(mediaContainer);
      ytStartTracking();
    }

    // Remove mini-player chrome (but don't pause/move content for YT)
    if (miniPlayerEl) {
      if (!isYT) {
        // For native video, move content back
        const mediaWrap = document.getElementById('mini-player-media');
        const content = mediaWrap?.querySelector('video');
        if (content && miniPlayerSource) {
          miniPlayerSource.innerHTML = '';
          miniPlayerSource.appendChild(content);
          content.style.cssText = 'width:100%;height:100%';
          content.classList.add('w-full', 'h-full');
          miniPlayerSource.style.display = '';
        }
      }
      miniPlayerEl.remove();
      miniPlayerEl = null;
    }
    miniPlayerSource = null;
  }

  // Observe video/iframe containers for scroll-away
  const miniPlayerObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const container = entry.target;
      if (!entry.isIntersecting) {
        // Scrolled out of view
        const isYT = container === ytActiveContainer;
        const content = isYT ? ytSharedIframe : container.querySelector('video');
        if (!content && !isYT) return;

        // If mini-player is disabled, pause/stop when scrolled away
        if (!socialSettings.miniPlayerEnabled) {
          if (!isYT && content?.tagName === 'VIDEO' && !content.paused) content.pause();
          if (isYT && ytSharedIframe?._userActivated) {
            pauseYTPlayer();
            hideYTWrapper();
          }
          return;
        }

        // Mini-player enabled — activate if user was watching
        if (!isYT && content?.tagName === 'VIDEO' && content.paused) return;
        if (isYT && !ytSharedIframe?._userActivated) return;
        if (miniPlayerSource === container) return; // already active
        if (miniPlayerEl) closeMiniPlayer(); // close any existing
        activateMiniPlayer(container);
      } else {
        // Scrolled back into view — return to inline
        if (miniPlayerSource === container) {
          deactivateMiniPlayer(container);
        }
      }
    });
  }, { threshold: 0.15 });

  function addIframeOverlay(container, iframe) {
    container.style.position = 'relative';
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position:absolute;inset:0;z-index:5;cursor:pointer';
    overlay.addEventListener('click', () => {
      iframe._userActivated = true;
      pauseAllMedia(iframe);
      overlay.remove();
    });
    container.appendChild(overlay);
  }

  function pauseAllMedia(except) {
    document.querySelectorAll('.aspect-video video').forEach(v => {
      if (v !== except && !v.paused) v.pause();
    });
    // Pause the shared YT player if it's not the exception
    if (ytSharedIframe && ytSharedIframe !== except && ytSharedIframe._userActivated) {
      pauseYTPlayer();
    }
  }

  function observeVideos() {
    document.querySelectorAll('.aspect-video').forEach(container => {
      if (container._miniPlayerObserved) return;
      container._miniPlayerObserved = true;
      miniPlayerObserver.observe(container);
      // For HLS videos, track play/pause and pause others on play
      const video = container.querySelector('video');
      if (video && !video._playListenerAdded) {
        video._playListenerAdded = true;
        video.addEventListener('play', () => { video._wasPlaying = true; pauseAllMedia(video); });
        video.addEventListener('pause', () => { video._wasPlaying = false; });
      }
    });
  }

  // ============================================================
  // SINGLE SHARED YOUTUBE PLAYER — never move the iframe in the DOM
  // Moving iframes between DOM parents causes browser to reload them (= new ads).
  // Instead we keep the iframe in a permanent fixed-position wrapper and reposition
  // it visually over whichever container is active.
  // ============================================================
  let ytSharedIframe = null;
  let ytWrapper = null; // fixed-position wrapper, always in document.body
  let ytActiveContainer = null; // which .aspect-video is logically active
  let ytApiReady = false;
  let ytPendingVideoId = null;
  const ytOrigin = window.location.origin;
  let ytPositionRAF = null;

  function getOrCreateYTIframe() {
    if (ytSharedIframe) return ytSharedIframe;

    // Create permanent wrapper — stays in body forever
    ytWrapper = document.createElement('div');
    ytWrapper.style.cssText = 'position:fixed;z-index:40;pointer-events:auto;display:none;overflow:hidden;border-radius:0';
    document.body.appendChild(ytWrapper);

    ytSharedIframe = document.createElement('iframe');
    ytSharedIframe.setAttribute('frameborder', '0');
    ytSharedIframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
    ytSharedIframe.setAttribute('allowfullscreen', '');
    ytSharedIframe.style.cssText = 'width:100%;height:100%;border:none';
    ytWrapper.appendChild(ytSharedIframe);

    // Listen for YouTube player postMessage events
    window.addEventListener('message', (e) => {
      if (!ytSharedIframe) return;
      let data;
      try { data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data; } catch { return; }

      if (data.event === 'onStateChange') {
        const state = data.info;
        if (state === 1 || state === 3) {
          ytSharedIframe._userActivated = true;
        } else if (state === 2 || state === 0) {
          ytSharedIframe._userActivated = false;
        }
      }

      if (data.event === 'initialDelivery' || data.event === 'onReady') {
        ytApiReady = true;
        if (ytPendingVideoId) {
          const vid = ytPendingVideoId;
          ytPendingVideoId = null;
          ytSendCommand('loadVideoById', [vid]);
        }
      }
    });

    return ytSharedIframe;
  }

  function ytSendCommand(func, args) {
    if (!ytSharedIframe?.contentWindow) return;
    try {
      ytSharedIframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func, args: args || '' }), '*');
    } catch {}
  }

  function ytHandshake() {
    if (!ytSharedIframe?.contentWindow) return;
    try {
      ytSharedIframe.contentWindow.postMessage(JSON.stringify({ event: 'listening', id: 1 }), '*');
    } catch {}
    ytSendCommand('addEventListener', ['onStateChange']);
  }

  // Position the fixed wrapper over a target element
  function ytPositionOver(target) {
    if (!ytWrapper || !target) return;
    const rect = target.getBoundingClientRect();
    ytWrapper.style.left = rect.left + 'px';
    ytWrapper.style.top = rect.top + 'px';
    ytWrapper.style.width = rect.width + 'px';
    ytWrapper.style.height = rect.height + 'px';
    ytWrapper.style.display = '';
  }

  // Continuously reposition over the active container (handles scroll)
  function ytStartTracking() {
    ytStopTracking();
    function update() {
      if (ytActiveContainer && ytWrapper && ytWrapper.style.display !== 'none' && !ytWrapper._miniPlayerMode) {
        ytPositionOver(ytActiveContainer);
      }
      ytPositionRAF = requestAnimationFrame(update);
    }
    ytPositionRAF = requestAnimationFrame(update);
  }

  function ytStopTracking() {
    if (ytPositionRAF) { cancelAnimationFrame(ytPositionRAF); ytPositionRAF = null; }
  }

  function playYTVideo(container, videoId) {
    pauseAllMedia(null);
    const iframe = getOrCreateYTIframe();

    // If another container was active, restore its placeholder
    if (ytActiveContainer && ytActiveContainer !== container) {
      returnYTPlaceholder(ytActiveContainer);
    }

    // Save original placeholder content & hide it (wrapper overlays it)
    if (!container._ytPlaceholderHTML) {
      container._ytPlaceholderHTML = container.innerHTML;
    }
    container.innerHTML = '<div style="width:100%;aspect-ratio:16/9;background:#000"></div>';
    container.style.cursor = '';
    container.classList.remove('yt-placeholder');
    ytActiveContainer = container;

    // Position wrapper over this container
    ytWrapper._miniPlayerMode = false;
    ytWrapper.style.borderRadius = '0';
    ytPositionOver(container);
    ytStartTracking();

    // Load video: first time sets src; subsequent use postMessage (no reload, no ads)
    if (!iframe._firstLoaded) {
      iframe._firstLoaded = true;
      ytApiReady = false;
      ytPendingVideoId = null;
      iframe.src = `https://www.youtube.com/embed/${videoId}?enablejsapi=1&autoplay=1&origin=${encodeURIComponent(ytOrigin)}`;
      iframe.addEventListener('load', () => { setTimeout(ytHandshake, 300); }, { once: true });
    } else if (ytApiReady) {
      ytSendCommand('loadVideoById', [videoId]);
    } else {
      ytPendingVideoId = videoId;
    }

    iframe._userActivated = true;

    // Observe this container for scroll-away behavior
    if (!container._miniPlayerObserved) {
      container._miniPlayerObserved = true;
      miniPlayerObserver.observe(container);
    }
  }

  function returnYTPlaceholder(container) {
    if (!container) return;
    // Restore the thumbnail placeholder
    if (container._ytPlaceholderHTML) {
      container.innerHTML = container._ytPlaceholderHTML;
      container.style.cursor = 'pointer';
      container.classList.add('yt-placeholder');
    }
    if (ytActiveContainer === container) ytActiveContainer = null;
  }

  function hideYTWrapper() {
    if (ytWrapper) { ytWrapper.style.display = 'none'; }
    ytStopTracking();
  }

  function pauseYTPlayer() {
    if (ytSharedIframe) {
      ytSendCommand('pauseVideo');
      ytSharedIframe._userActivated = false;
    }
  }

  function initYTPlaceholders() {
    document.querySelectorAll('.yt-placeholder:not([data-yt-bound])').forEach(container => {
      container.dataset.ytBound = '1';
      container.addEventListener('click', () => {
        const videoId = container.dataset.ytId;
        if (videoId) playYTVideo(container, videoId);
      });
    });
  }

  // ============================================================
  // SQUADS (kept from original)
  // ============================================================
  async function initSquadsProfile() {
    if (squadsInitialized) return;
    squadsInitialized = true;
    try {
      const session = await ensureBskySession();
      myHandle = session?.handle || null;
      myDid = session?.did || null;
      if (myHandle) {
        const profileRes = await fetchTimeout(`https://public.api.bsky.app/xrpc/app.bsky.actor.getProfile?actor=${encodeURIComponent(myHandle)}`, {}, 8000);
